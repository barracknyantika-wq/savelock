---
import '../styles/global.css';

interface Props {
  title?: string;
  tab?: 'today' | 'report' | 'goals' | 'settings';
}

const { title = 'SaveLock', tab = 'today' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');

const tabs = [
  { id: 'today', href: `${base}/`, label: 'Today' },
  { id: 'report', href: `${base}/report/`, label: 'Report' },
  { id: 'goals', href: `${base}/goals/`, label: 'Goals' },
  { id: 'settings', href: `${base}/settings/`, label: 'Settings' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta
      name="description"
      content="A discipline layer for your savings. Holds no money, just keeps score."
    />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={`${base}/icons/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}/manifest.webmanifest`} />
    <meta name="theme-color" content="#0f0e0c" />
    <meta name="color-scheme" content="dark" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="SaveLock" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  </head>
  <body class="canvas-grain min-h-dvh font-sans text-cream antialiased">
    <!--
      Mandatory sign-in gate. Whenever cloud sync is configured and the
      shared auth store hasn't reached a fully resolved, signed-in state
      yet, this is the ONLY thing visible on any page, Home/Report/Goals/
      Settings/Account included, there is no dismiss button and no way to
      navigate past it, see src/scripts/app.js's Alpine.store('auth', ...)
      for the state machine this renders. Local-only builds (cloud sync not
      configured at all) never show this, $store.auth.blocked is always
      false there.
    -->
    <div x-data x-show="$store.auth.blocked" x-cloak class="fixed inset-0 z-[60] overflow-y-auto bg-canvas px-5 py-10">
      <div class="mx-auto w-full max-w-md">
        <template x-if="$store.auth.stage === 'checking'">
          <p class="pt-16 text-center text-sm font-light text-cream-2">Loading…</p>
        </template>

        <template x-if="$store.auth.stage === 'phone' || $store.auth.stage === 'otp'">
          <div class="pt-8">
            <h1 class="mb-1 px-1 font-display text-2xl font-semibold tracking-tight text-cream">Welcome to SaveLock</h1>
            <p class="mb-7 px-1 text-sm font-light leading-relaxed text-cream-2">
              New here? Enter your details below to get started. Already have an account? Sign in the
              same way, and everything you tracked before comes right back. This app still holds no
              money either way, an account only keeps your own tracking data safe if you switch phones
              or reinstall.
            </p>

            <template x-if="$store.auth.stage === 'phone'">
              <section class="paper relative rotate-[-0.5deg] p-5">
                <h2 class="font-display text-lg font-semibold text-ink">Sign in or create an account</h2>

                <button
                  type="button"
                  @click="$store.auth.startGoogleSignIn()"
                  :disabled="$store.auth.busy"
                  class="pressable mt-4 flex min-h-12 w-full items-center justify-center gap-2 rounded-xl border border-paper-line bg-paper font-semibold text-ink disabled:opacity-50"
                >
                  <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                    <path fill="#4285F4" d="M23.5 12.27c0-.85-.08-1.67-.22-2.45H12v4.64h6.46c-.28 1.5-1.13 2.77-2.4 3.62v3h3.88c2.27-2.09 3.56-5.17 3.56-8.81z"/>
                    <path fill="#34A853" d="M12 24c3.24 0 5.96-1.07 7.94-2.92l-3.88-3c-1.08.72-2.45 1.15-4.06 1.15-3.12 0-5.77-2.11-6.71-4.94H1.28v3.1C3.25 21.3 7.31 24 12 24z"/>
                    <path fill="#FBBC05" d="M5.29 14.29a7.2 7.2 0 010-4.58v-3.1H1.28a12 12 0 000 10.78z"/>
                    <path fill="#EA4335" d="M12 4.75c1.76 0 3.34.61 4.59 1.8l3.44-3.44C17.95 1.19 15.24 0 12 0 7.31 0 3.25 2.7 1.28 6.61l4.01 3.1C6.23 6.86 8.88 4.75 12 4.75z"/>
                  </svg>
                  <span x-text="$store.auth.busy ? 'Opening Google…' : 'Sign in with Google'"></span>
                </button>

                <div class="my-4 flex items-center gap-3 text-xs font-medium text-ink-3">
                  <div class="h-px flex-1 bg-paper-line"></div>
                  <span>or</span>
                  <div class="h-px flex-1 bg-paper-line"></div>
                </div>

                <form @submit.prevent="$store.auth.sendCode()">
                  <label class="block text-sm font-medium text-ink-2" for="gate-name">Name</label>
                  <input
                    id="gate-name"
                    x-model="$store.auth.name"
                    type="text"
                    autocomplete="name"
                    placeholder="Jane Wanjiru"
                    class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
                  />
                  <label class="mt-3 block text-sm font-medium text-ink-2" for="gate-phone">Phone number</label>
                  <input
                    id="gate-phone"
                    x-model="$store.auth.phone"
                    type="tel"
                    inputmode="tel"
                    autocomplete="tel"
                    placeholder="+2547..."
                    class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
                  />
                  <p x-show="$store.auth.error" x-cloak class="mt-2 text-sm font-medium text-brick" x-text="$store.auth.error"></p>
                  <button
                    type="submit"
                    :disabled="$store.auth.busy"
                    class="pressable mt-4 min-h-12 w-full rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)] disabled:opacity-50"
                  >
                    <span x-text="$store.auth.busy ? 'Sending…' : 'Send code'"></span>
                  </button>
                </form>
              </section>
            </template>

            <template x-if="$store.auth.stage === 'otp'">
              <section class="paper relative rotate-[-0.5deg] p-5">
                <h2 class="font-display text-lg font-semibold text-ink">Enter the code</h2>
                <p class="mt-1 text-sm font-light text-ink-2">
                  Sent by SMS to <span class="font-semibold text-ink" x-text="$store.auth.phone"></span>.
                </p>
                <form class="mt-4" @submit.prevent="$store.auth.verifyCode()">
                  <label class="block text-sm font-medium text-ink-2" for="gate-otp">Code</label>
                  <input
                    id="gate-otp"
                    x-model="$store.auth.otp"
                    type="text"
                    inputmode="numeric"
                    autocomplete="one-time-code"
                    maxlength="8"
                    placeholder="123456"
                    class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
                  />
                  <p x-show="$store.auth.error" x-cloak class="mt-2 text-sm font-medium text-brick" x-text="$store.auth.error"></p>
                  <button
                    type="submit"
                    :disabled="$store.auth.busy"
                    class="pressable mt-4 min-h-12 w-full rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)] disabled:opacity-50"
                  >
                    <span x-text="$store.auth.busy ? 'Verifying…' : 'Verify'"></span>
                  </button>
                  <button
                    type="button"
                    @click="$store.auth.stage = 'phone'; $store.auth.otp = ''; $store.auth.error = ''"
                    class="pressable mt-2 min-h-11 w-full rounded-xl text-sm font-medium text-ink-3"
                  >
                    Use a different number
                  </button>
                </form>
              </section>
            </template>
          </div>
        </template>

        <template x-if="$store.auth.stage === 'import'">
          <div class="pt-16">
            <section class="paper relative rotate-[-0.5deg] p-5">
              <h2 class="font-display text-lg font-semibold text-ink">Import your existing data?</h2>
              <p class="mt-2 text-sm font-light leading-relaxed text-ink-2">
                This account doesn't have any data yet, but this device does. Bring your current
                allowance, goals, and streak into your account so nothing already tracked here is lost.
              </p>
              <button
                type="button"
                @click="$store.auth.importLocalData()"
                :disabled="$store.auth.busy"
                class="pressable mt-4 min-h-12 w-full rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)] disabled:opacity-50"
              >
                <span x-text="$store.auth.busy ? 'Importing…' : 'Import this device data'"></span>
              </button>
            </section>
          </div>
        </template>

        <template x-if="$store.auth.stage === 'reconcile'">
          <div class="pt-16">
            <section class="paper relative rotate-[-0.5deg] p-5">
              <h2 class="font-display text-lg font-semibold text-ink">Two copies of your data exist</h2>
              <p class="mt-2 text-sm font-light leading-relaxed text-ink-2">
                This device already has its own tracking, and your account already has data from
                somewhere else. Pick which one to keep. The other is not merged in automatically, so
                nothing gets silently combined or lost without you choosing.
              </p>
              <div class="mt-4 space-y-2">
                <button
                  type="button"
                  @click="$store.auth.keepThisDevice()"
                  :disabled="$store.auth.busy"
                  class="chip pressable flex min-h-12 w-full items-center justify-center rounded-xl font-semibold text-ink disabled:opacity-50"
                >
                  Keep this device's data
                </button>
                <button
                  type="button"
                  @click="$store.auth.useAccountData()"
                  :disabled="$store.auth.busy"
                  class="chip pressable flex min-h-12 w-full items-center justify-center rounded-xl font-semibold text-ink disabled:opacity-50"
                >
                  Use my account's data
                </button>
              </div>
            </section>
          </div>
        </template>
      </div>
    </div>

    <div x-data x-show="!$store.auth.blocked" x-cloak>
      <slot />
    </div>

    <!-- global toast: one confirmation surface, shared by every page -->
    <div
      x-data
      x-show="$store.toast.message"
      x-cloak
      x-transition:enter="transition duration-200 ease-out"
      x-transition:enter-start="opacity-0 translate-y-2"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition duration-150 ease-in"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 translate-y-2"
      class="fixed bottom-[calc(env(safe-area-inset-bottom)+86px)] left-1/2 z-50 -translate-x-1/2 whitespace-nowrap rounded-full bg-ink px-4 py-2 text-sm font-semibold text-cream shadow-[0_6px_20px_-6px_rgba(0,0,0,0.7)]"
      role="status"
      aria-live="polite"
    >
      <span x-text="$store.toast.message"></span>
    </div>

    <!-- floating pill nav, off the bottom edge -->
    <nav
      x-data
      x-show="!$store.auth.blocked"
      x-cloak
      class="fixed bottom-[calc(env(safe-area-inset-bottom)+14px)] left-1/2 z-40 w-[min(92%,380px)] -translate-x-1/2"
      aria-label="Main"
    >
      <div class="paper-dark flex items-end justify-around rounded-full px-3 pb-2 pt-2">
        {
          tabs.map((t) => (
            <a
              href={t.href}
              aria-current={t.id === tab ? 'page' : undefined}
              class="flex min-h-12 min-w-14 flex-col items-center justify-end gap-0.5"
            >
              <span
                class:list={[
                  'flex items-center justify-center rounded-full transition-transform',
                  t.id === tab
                    ? 'h-12 w-12 -translate-y-5 bg-paper text-ink shadow-[0_6px_16px_-4px_rgba(0,0,0,0.7),0_2px_0_rgba(0,0,0,0.35)] ring-4 ring-canvas'
                    : 'h-9 w-9 text-cream-2',
                ]}
              >
                {t.id === 'today' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="2.5" y="6" width="19" height="12" rx="2.5" />
                    <circle cx="12" cy="12" r="2.4" />
                    <path d="M6 12h.01M18 12h.01" />
                  </svg>
                )}
                {t.id === 'report' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 20V10M11 20V4M18 20v-7" />
                  </svg>
                )}
                {t.id === 'goals' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="5" y="10.5" width="14" height="9.5" rx="2.5" />
                    <path d="M8 10.5V8a4 4 0 0 1 8 0v2.5" />
                    <circle cx="12" cy="15.2" r="1.4" fill="currentColor" stroke="none" />
                  </svg>
                )}
                {t.id === 'settings' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 7h16M4 12h16M4 17h16" />
                    <circle cx="9" cy="7" r="2" fill="currentColor" stroke="none" />
                    <circle cx="15" cy="12" r="2" fill="currentColor" stroke="none" />
                    <circle cx="8" cy="17" r="2" fill="currentColor" stroke="none" />
                  </svg>
                )}
              </span>
              <span
                class:list={[
                  'text-[10px] font-medium tracking-wide',
                  t.id === tab ? '-translate-y-3 text-cream' : 'text-cream-2',
                ]}
              >
                {t.label}
              </span>
            </a>
          ))
        }
      </div>
    </nav>

    <script src="../scripts/app.js"></script>
    <script is:inline define:vars={{ swUrl: `${base}/sw.js`, prod: import.meta.env.PROD }}>
      if (prod && 'serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(swUrl).catch(() => {});
        });
      }
    </script>
  </body>
</html>
