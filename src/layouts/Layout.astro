---
import '../styles/global.css';

interface Props {
  title?: string;
  tab?: 'today' | 'goals' | 'settings';
}

const { title = 'SaveLock', tab = 'today' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');

const tabs = [
  { id: 'today', href: `${base}/`, label: 'Today' },
  { id: 'goals', href: `${base}/goals/`, label: 'Goals' },
  { id: 'settings', href: `${base}/settings/`, label: 'Settings' },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta
      name="description"
      content="A discipline layer for your savings. Holds no money — just keeps score."
    />
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={`${base}/icons/apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}/manifest.webmanifest`} />
    <meta name="theme-color" content="#0f0e0c" />
    <meta name="color-scheme" content="dark" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="SaveLock" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  </head>
  <body class="canvas-grain min-h-dvh font-sans text-cream antialiased">
    <slot />

    <!-- global toast: one confirmation surface, shared by every page -->
    <div
      x-data
      x-show="$store.toast.message"
      x-cloak
      x-transition:enter="transition duration-200 ease-out"
      x-transition:enter-start="opacity-0 translate-y-2"
      x-transition:enter-end="opacity-100 translate-y-0"
      x-transition:leave="transition duration-150 ease-in"
      x-transition:leave-start="opacity-100 translate-y-0"
      x-transition:leave-end="opacity-0 translate-y-2"
      class="fixed bottom-[calc(env(safe-area-inset-bottom)+86px)] left-1/2 z-50 -translate-x-1/2 whitespace-nowrap rounded-full bg-ink px-4 py-2 text-sm font-semibold text-cream shadow-[0_6px_20px_-6px_rgba(0,0,0,0.7)]"
      role="status"
      aria-live="polite"
    >
      <span x-text="$store.toast.message"></span>
    </div>

    <!-- floating pill nav, off the bottom edge -->
    <nav
      class="fixed bottom-[calc(env(safe-area-inset-bottom)+14px)] left-1/2 z-40 w-[min(88%,340px)] -translate-x-1/2"
      aria-label="Main"
    >
      <div class="paper-dark flex items-end justify-around rounded-full px-4 pb-2 pt-2">
        {
          tabs.map((t) => (
            <a
              href={t.href}
              aria-current={t.id === tab ? 'page' : undefined}
              class="flex min-h-12 min-w-16 flex-col items-center justify-end gap-0.5"
            >
              <span
                class:list={[
                  'flex items-center justify-center rounded-full transition-transform',
                  t.id === tab
                    ? 'h-12 w-12 -translate-y-5 bg-paper text-ink shadow-[0_6px_16px_-4px_rgba(0,0,0,0.7),0_2px_0_rgba(0,0,0,0.35)] ring-4 ring-canvas'
                    : 'h-9 w-9 text-cream-2',
                ]}
              >
                {t.id === 'today' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="2.5" y="6" width="19" height="12" rx="2.5" />
                    <circle cx="12" cy="12" r="2.4" />
                    <path d="M6 12h.01M18 12h.01" />
                  </svg>
                )}
                {t.id === 'goals' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="5" y="10.5" width="14" height="9.5" rx="2.5" />
                    <path d="M8 10.5V8a4 4 0 0 1 8 0v2.5" />
                    <circle cx="12" cy="15.2" r="1.4" fill="currentColor" stroke="none" />
                  </svg>
                )}
                {t.id === 'settings' && (
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 7h16M4 12h16M4 17h16" />
                    <circle cx="9" cy="7" r="2" fill="currentColor" stroke="none" />
                    <circle cx="15" cy="12" r="2" fill="currentColor" stroke="none" />
                    <circle cx="8" cy="17" r="2" fill="currentColor" stroke="none" />
                  </svg>
                )}
              </span>
              <span
                class:list={[
                  'text-[10px] font-medium tracking-wide',
                  t.id === tab ? '-translate-y-3 text-cream' : 'text-cream-2',
                ]}
              >
                {t.label}
              </span>
            </a>
          ))
        }
      </div>
    </nav>

    <script src="../scripts/app.js"></script>
    <script is:inline define:vars={{ swUrl: `${base}/sw.js`, prod: import.meta.env.PROD }}>
      if (prod && 'serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register(swUrl).catch(() => {});
        });
      }
    </script>
  </body>
</html>
