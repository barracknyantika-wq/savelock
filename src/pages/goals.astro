---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SaveLock: Goals" tab="goals">
  <main x-data="goalsPage" class="mx-auto w-full max-w-md px-5 pb-44 pt-7">
    <header class="mb-2 flex items-center justify-between px-1">
      <h1 class="font-display text-xl font-semibold tracking-tight text-cream">Goals</h1>
      <button
        type="button"
        @click="openNew"
        class="pressable min-h-11 rounded-full bg-ochre px-5 text-sm font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)]"
      >
        New goal
      </button>
    </header>

    <p class="mb-7 px-1 text-xs font-light leading-relaxed text-cream-2">
      The real money stays in your M-Shwari Lock or bank. SaveLock only keeps score.
    </p>

    <p
      x-show="milestoneBanner"
      x-cloak
      x-transition
      class="mb-5 flex items-start gap-1.5 rounded-xl bg-ochre/10 px-3 py-2.5 text-sm text-ochre-deep"
    >
      <span x-html="$handCheck()"></span>
      <span x-text="milestoneBanner"></span>
    </p>

    <!-- Empty state -->
    <p
      x-show="!$store.sl.activeGoals.length"
      x-cloak
      class="rotate-[-1deg] rounded-2xl border border-dashed border-charcoal-2 px-6 py-7 text-center text-sm leading-relaxed text-cream-2"
    >
      No goals yet. Lock a target and a date. The waiting is the work.
    </p>

    <!-- Active goals -->
    <div class="space-y-5">
      <template x-for="(g, gi) in $store.sl.activeGoals" :key="g.id">
        <section
          class="paper relative p-5"
          :class="gi % 2 === 0 ? 'rotate-[-1deg] mr-3' : 'rotate-[0.8deg] ml-3'"
          :style="($store.sl.reached(g) || $store.sl.matured(g)) ? 'box-shadow: 0 0 0 2px #c9922e, 0 14px 34px -14px rgba(8,6,3,.8)' : ''"
        >
          <div class="flex items-start justify-between gap-4">
            <div class="min-w-0">
              <h2 class="truncate font-display text-xl font-semibold tracking-tight text-ink" x-text="g.name"></h2>
              <p class="mt-0.5 text-sm font-light text-ink-2">
                <span class="font-semibold text-ink" x-text="$store.sl.money(g.saved)"></span>
                <span x-text="' of ' + $store.sl.money(g.target)"></span>
              </p>
            </div>
            <!-- small tick gauge -->
            <div
              class="relative w-24 shrink-0"
              role="progressbar"
              :aria-label="'Progress toward ' + g.name"
              :aria-valuenow="Math.round($store.sl.progress(g) * 100)"
              aria-valuemin="0"
              aria-valuemax="100"
            >
              <div x-html="goalGauge(g)"></div>
              <p
                class="absolute inset-x-0 bottom-0 text-center font-display text-sm font-semibold text-ink"
                x-text="Math.round($store.sl.progress(g) * 100) + '%'"
              ></p>
            </div>
          </div>

          <!-- Celebration state -->
          <template x-if="$store.sl.reached(g) || $store.sl.matured(g)">
            <div class="mt-4 rounded-xl border border-ochre/40 bg-ochre/10 p-4">
              <p class="font-display text-lg font-semibold text-ochre-deep">
                <span x-html="$handCheck()"></span>
                <span x-text="$store.sl.reached(g) ? 'Target hit.' : 'You made it to the date.'"></span>
              </p>
              <p class="mt-1 text-sm font-light leading-relaxed text-ink-2">
                <span x-show="!$store.sl.matured(g)" x-text="$store.sl.daysLeft(g) + ' days ahead of schedule. '"></span>
                The money is in your real account, not here. Withdraw it there, then mark this done.
              </p>
              <button
                type="button"
                @click="$store.sl.completeGoal(g.id); $toast('Saved')"
                class="pressable mt-3 min-h-11 w-full rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)]"
              >
                Mark done
              </button>
            </div>
          </template>

          <!-- Countdown -->
          <template x-if="!($store.sl.reached(g) || $store.sl.matured(g))">
            <div>
              <p class="mt-3 text-sm font-light text-ink-2">
                <span class="font-display text-4xl font-bold tracking-tight text-ink" x-text="$store.sl.daysLeft(g)"></span>
                <span x-text="($store.sl.daysLeft(g) === 1 ? ' day' : ' days') + ' until ' + $store.sl.dateShort(g.date)"></span>
              </p>
              <p x-show="projectedDate(g)" x-cloak class="mt-1 text-xs font-light text-ink-3">
                At your recent pace, roughly <span class="font-semibold text-ink-2" x-text="projectedDate(g)"></span>
              </p>
            </div>
          </template>

          <div class="mt-4 flex items-center justify-between gap-3 border-t border-dashed border-paper-line pt-3.5">
            <button
              type="button"
              @click="openUpdate(g)"
              class="chip pressable min-h-11 flex-1 rounded-xl text-sm font-semibold text-ink"
            >
              Update saved
            </button>
            <template x-if="!($store.sl.reached(g) || $store.sl.matured(g))">
              <button
                type="button"
                @click="startBreak(g)"
                class="pressable min-h-11 rounded-xl px-3 text-sm font-medium text-ink-3 active:text-brick"
              >
                Break early
              </button>
            </template>
          </div>

          <div x-show="cloudConfigured" x-cloak class="mt-2.5 flex items-center gap-3">
            <button
              type="button"
              @click="openDeposit(g)"
              class="chip pressable min-h-11 flex-1 rounded-xl text-sm font-semibold text-ink"
            >
              Deposit
            </button>
            <template x-if="isOwner">
              <button
                type="button"
                @click="openWithdraw(g)"
                class="chip pressable min-h-11 flex-1 rounded-xl text-sm font-semibold text-ink"
              >
                Withdraw
              </button>
            </template>
          </div>
        </section>
      </template>
    </div>

    <!-- Past goals -->
    <details x-show="$store.sl.pastGoals.length" x-cloak class="mt-9 px-1">
      <summary class="cursor-pointer select-none text-sm font-medium text-cream-2">
        Past goals (<span x-text="$store.sl.pastGoals.length"></span>)
      </summary>
      <ul class="mt-3 space-y-3">
        <template x-for="g in $store.sl.pastGoals" :key="g.id">
          <li class="paper-dark rounded-2xl p-4">
            <div class="flex items-baseline justify-between gap-3">
              <p class="min-w-0 truncate font-semibold text-cream" x-text="g.name"></p>
              <p
                class="shrink-0 text-xs font-bold uppercase tracking-wider"
                :class="g.status === 'done' ? 'text-ochre' : 'text-brick-bright'"
                x-text="g.status === 'done' ? 'Done' : 'Broken'"
              ></p>
            </div>
            <p class="mt-1 text-xs font-light text-cream-2">
              <span x-text="$store.sl.money(g.saved) + ' of ' + $store.sl.money(g.target)"></span>
              <span
                x-text="g.status === 'done'
                  ? ' · completed ' + $store.sl.dateShort(g.completedAt)
                  : ' · broken ' + g.daysEarly + ' days early' + (g.streakLost ? ', lost a ' + g.streakLost + '-day streak' : '')"
              ></span>
            </p>
          </li>
        </template>
      </ul>
    </details>

    <!-- New goal sheet -->
    <div x-show="newSheet" x-cloak class="fixed inset-0 z-50" role="dialog" aria-modal="true" aria-label="New goal">
      <div class="absolute inset-0 bg-black/60" x-show="newSheet" x-transition.opacity.duration.150ms @click="newSheet = false"></div>
      <form
        @submit.prevent="submitNew"
        x-show="newSheet"
        x-transition:enter="transition duration-200 ease-out"
        x-transition:enter-start="translate-y-full"
        x-transition:enter-end="translate-y-0"
        x-transition:leave="transition duration-150 ease-in"
        x-transition:leave-start="translate-y-0"
        x-transition:leave-end="translate-y-full"
        class="paper absolute inset-x-0 bottom-0 rounded-b-none rounded-t-3xl p-5 pb-[calc(1.5rem+env(safe-area-inset-bottom))]"
      >
        <div class="mx-auto max-w-md">
          <div class="mx-auto mb-3 h-1.5 w-10 rounded-full bg-paper-line" aria-hidden="true"></div>
          <h3 class="font-display text-xl font-semibold tracking-tight">New goal</h3>
          <p class="mt-1 text-xs font-light text-ink-2">
            Match it to a real lock, the one where the money actually sits.
          </p>
          <label class="mt-4 block text-sm font-medium text-ink-2" for="goal-name">Name</label>
          <input
            id="goal-name"
            x-model="gName"
            type="text"
            maxlength="40"
            required
            placeholder="Emergency fund"
            class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
          />
          <label class="mt-3 block text-sm font-medium text-ink-2" for="goal-target">Target amount</label>
          <input
            id="goal-target"
            x-model="gTarget"
            type="number"
            inputmode="decimal"
            min="1"
            step="any"
            required
            placeholder="20,000"
            class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
          />
          <label class="mt-3 block text-sm font-medium text-ink-2" for="goal-date">Withdraw date</label>
          <input
            id="goal-date"
            x-model="gDate"
            type="date"
            :min="minDate"
            required
            class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none focus:border-ochre-soft"
          />
          <div class="mt-5 flex gap-3">
            <button type="button" @click="newSheet = false" class="pressable min-h-12 flex-1 rounded-xl border border-paper-line font-semibold text-ink-2">
              Cancel
            </button>
            <button type="submit" class="pressable min-h-12 flex-1 rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)]">
              Lock it in
            </button>
          </div>
        </div>
      </form>
    </div>

    <!-- Update saved sheet -->
    <div x-show="updSheet" x-cloak class="fixed inset-0 z-50" role="dialog" aria-modal="true" aria-label="Update saved amount">
      <div class="absolute inset-0 bg-black/60" x-show="updSheet" x-transition.opacity.duration.150ms @click="updSheet = false"></div>
      <form
        @submit.prevent="submitUpdate"
        x-show="updSheet"
        x-transition:enter="transition duration-200 ease-out"
        x-transition:enter-start="translate-y-full"
        x-transition:enter-end="translate-y-0"
        x-transition:leave="transition duration-150 ease-in"
        x-transition:leave-start="translate-y-0"
        x-transition:leave-end="translate-y-full"
        class="paper absolute inset-x-0 bottom-0 rounded-b-none rounded-t-3xl p-5 pb-[calc(1.5rem+env(safe-area-inset-bottom))]"
      >
        <div class="mx-auto max-w-md">
          <div class="mx-auto mb-3 h-1.5 w-10 rounded-full bg-paper-line" aria-hidden="true"></div>
          <h3 class="font-display text-xl font-semibold tracking-tight" x-text="'Update “' + updName + '”'"></h3>
          <label class="mt-4 block text-sm font-medium text-ink-2" for="upd-amount">Total saved so far</label>
          <p class="mt-1 text-xs font-light text-ink-2">
            Enter what's actually sitting in the real lock right now.
          </p>
          <input
            id="upd-amount"
            x-ref="updInput"
            x-model="updAmount"
            type="number"
            inputmode="decimal"
            min="0"
            step="any"
            placeholder="0"
            class="mt-2 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
          />
          <div class="mt-5 flex gap-3">
            <button type="button" @click="updSheet = false" class="pressable min-h-12 flex-1 rounded-xl border border-paper-line font-semibold text-ink-2">
              Cancel
            </button>
            <button type="submit" class="pressable min-h-12 flex-1 rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)]">
              Save
            </button>
          </div>
        </div>
      </form>
    </div>

    <!-- Deposit sheet: M-Pesa STK Push -->
    <div x-show="depGoalId" x-cloak class="fixed inset-0 z-50" role="dialog" aria-modal="true" aria-label="Deposit to goal">
      <div
        class="absolute inset-0 bg-black/60"
        x-show="depGoalId"
        x-transition.opacity.duration.150ms
        @click="depStage === 'form' && closeDeposit()"
      ></div>
      <template x-if="depositGoal">
        <div
          x-show="depGoalId"
          x-transition:enter="transition duration-200 ease-out"
          x-transition:enter-start="translate-y-full"
          x-transition:enter-end="translate-y-0"
          x-transition:leave="transition duration-150 ease-in"
          x-transition:leave-start="translate-y-0"
          x-transition:leave-end="translate-y-full"
          class="paper absolute inset-x-0 bottom-0 rounded-b-none rounded-t-3xl p-5 pb-[calc(1.5rem+env(safe-area-inset-bottom))]"
        >
          <div class="mx-auto max-w-md">
            <div class="mx-auto mb-3 h-1.5 w-10 rounded-full bg-paper-line" aria-hidden="true"></div>

            <template x-if="depStage === 'form'">
              <form @submit.prevent="submitDeposit">
                <h3 class="font-display text-xl font-semibold tracking-tight" x-text="'Deposit to “' + depositGoal.name + '”'"></h3>
                <p class="mt-1 text-xs font-light leading-relaxed text-ink-2">
                  You will get an M-Pesa prompt on your phone. Enter your PIN there to confirm.
                </p>
                <label class="mt-4 block text-sm font-medium text-ink-2" for="dep-amount">Amount</label>
                <input
                  id="dep-amount"
                  x-model="depAmount"
                  type="number"
                  inputmode="decimal"
                  min="1"
                  step="any"
                  required
                  placeholder="500"
                  class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
                />
                <label class="mt-3 block text-sm font-medium text-ink-2" for="dep-phone">Phone number</label>
                <input
                  id="dep-phone"
                  x-model="depPhone"
                  type="tel"
                  inputmode="tel"
                  autocomplete="tel"
                  required
                  placeholder="+2547..."
                  class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
                />
                <p x-show="depError" x-cloak class="mt-2 text-sm font-medium text-brick" x-text="depError"></p>
                <div class="mt-5 flex gap-3">
                  <button type="button" @click="closeDeposit" class="pressable min-h-12 flex-1 rounded-xl border border-paper-line font-semibold text-ink-2">
                    Cancel
                  </button>
                  <button
                    type="submit"
                    :disabled="depBusy"
                    class="pressable min-h-12 flex-1 rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)] disabled:opacity-50"
                  >
                    <span x-text="depBusy ? 'Starting…' : 'Continue'"></span>
                  </button>
                </div>
              </form>
            </template>

            <template x-if="depStage === 'checking'">
              <div class="py-4 text-center">
                <h3 class="font-display text-xl font-semibold tracking-tight">Check your phone</h3>
                <p class="mt-2 text-sm font-light leading-relaxed text-ink-2" x-text="depMessage"></p>
                <p class="mt-4 text-xs font-light text-ink-3">This updates on its own once the payment is confirmed.</p>
                <button type="button" @click="closeDeposit" class="pressable mt-5 min-h-11 w-full rounded-xl border border-paper-line font-semibold text-ink-2">
                  Close
                </button>
              </div>
            </template>

            <template x-if="depStage === 'done'">
              <div class="py-4 text-center">
                <p class="font-display text-2xl font-semibold text-ochre-deep">Deposit confirmed</p>
                <p class="mt-2 text-sm font-light text-ink-2" x-text="'Added to “' + depositGoal.name + '”.'"></p>
                <button
                  type="button"
                  @click="closeDeposit"
                  class="pressable mt-5 min-h-11 w-full rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)]"
                >
                  Done
                </button>
              </div>
            </template>

            <template x-if="depStage === 'failed'">
              <div class="py-4 text-center">
                <p class="font-display text-xl font-semibold text-brick-bright">Deposit did not go through</p>
                <p class="mt-2 text-sm font-light leading-relaxed text-ink-2" x-text="depError"></p>
                <button type="button" @click="closeDeposit" class="pressable mt-5 min-h-11 w-full rounded-xl border border-paper-line font-semibold text-ink-2">
                  Close
                </button>
              </div>
            </template>
          </div>
        </div>
      </template>
    </div>

    <!-- Withdraw sheet: M-Pesa B2C payout, owner only -->
    <div x-show="wdGoalId" x-cloak class="fixed inset-0 z-50" role="dialog" aria-modal="true" aria-label="Withdraw from goal">
      <div
        class="absolute inset-0 bg-black/60"
        x-show="wdGoalId"
        x-transition.opacity.duration.150ms
        @click="wdStage === 'form' && closeWithdraw()"
      ></div>
      <template x-if="withdrawGoal">
        <div
          x-show="wdGoalId"
          x-transition:enter="transition duration-200 ease-out"
          x-transition:enter-start="translate-y-full"
          x-transition:enter-end="translate-y-0"
          x-transition:leave="transition duration-150 ease-in"
          x-transition:leave-start="translate-y-0"
          x-transition:leave-end="translate-y-full"
          class="paper absolute inset-x-0 bottom-0 rounded-b-none rounded-t-3xl p-5 pb-[calc(1.5rem+env(safe-area-inset-bottom))]"
        >
          <div class="mx-auto max-w-md">
            <div class="mx-auto mb-3 h-1.5 w-10 rounded-full bg-paper-line" aria-hidden="true"></div>

            <template x-if="wdStage === 'form'">
              <form @submit.prevent="submitWithdraw">
                <h3 class="font-display text-xl font-semibold tracking-tight" x-text="'Withdraw from “' + withdrawGoal.name + '”'"></h3>
                <p class="mt-1 text-xs font-light leading-relaxed text-ink-2">
                  <span x-text="'Available through M-Pesa: ' + $store.sl.money(wdAvailable) + '.'"></span>
                </p>
                <label class="mt-4 block text-sm font-medium text-ink-2" for="wd-amount">Amount</label>
                <input
                  id="wd-amount"
                  x-model="wdAmount"
                  type="number"
                  inputmode="decimal"
                  min="1"
                  step="any"
                  required
                  placeholder="500"
                  class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
                />
                <label class="mt-3 block text-sm font-medium text-ink-2" for="wd-phone">Phone number</label>
                <input
                  id="wd-phone"
                  x-model="wdPhone"
                  type="tel"
                  inputmode="tel"
                  autocomplete="tel"
                  required
                  placeholder="+2547..."
                  class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
                />
                <p x-show="wdError" x-cloak class="mt-2 text-sm font-medium text-brick" x-text="wdError"></p>
                <div class="mt-5 flex gap-3">
                  <button type="button" @click="closeWithdraw" class="pressable min-h-12 flex-1 rounded-xl border border-paper-line font-semibold text-ink-2">
                    Cancel
                  </button>
                  <button
                    type="submit"
                    :disabled="wdBusy || wdAvailable <= 0"
                    class="pressable min-h-12 flex-1 rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)] disabled:opacity-50"
                  >
                    <span x-text="wdBusy ? 'Starting…' : 'Continue'"></span>
                  </button>
                </div>
              </form>
            </template>

            <template x-if="wdStage === 'checking'">
              <div class="py-4 text-center">
                <h3 class="font-display text-xl font-semibold tracking-tight">Processing your withdrawal</h3>
                <p class="mt-2 text-sm font-light leading-relaxed text-ink-2" x-text="wdMessage"></p>
                <p class="mt-4 text-xs font-light text-ink-3">This updates on its own once M-Pesa confirms it.</p>
                <button type="button" @click="closeWithdraw" class="pressable mt-5 min-h-11 w-full rounded-xl border border-paper-line font-semibold text-ink-2">
                  Close
                </button>
              </div>
            </template>

            <template x-if="wdStage === 'done'">
              <div class="py-4 text-center">
                <p class="font-display text-2xl font-semibold text-ochre-deep">Withdrawal sent</p>
                <p class="mt-2 text-sm font-light text-ink-2" x-text="'Sent from “' + withdrawGoal.name + '”.'"></p>
                <button
                  type="button"
                  @click="closeWithdraw"
                  class="pressable mt-5 min-h-11 w-full rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)]"
                >
                  Done
                </button>
              </div>
            </template>

            <template x-if="wdStage === 'failed'">
              <div class="py-4 text-center">
                <p class="font-display text-xl font-semibold text-brick-bright">Withdrawal did not go through</p>
                <p class="mt-2 text-sm font-light leading-relaxed text-ink-2" x-text="wdError"></p>
                <button type="button" @click="closeWithdraw" class="pressable mt-5 min-h-11 w-full rounded-xl border border-paper-line font-semibold text-ink-2">
                  Close
                </button>
              </div>
            </template>
          </div>
        </div>
      </template>
    </div>

    <!-- Break goal: deliberately high-friction, weighty and dark -->
    <div
      x-show="breakId"
      x-cloak
      class="fixed inset-0 z-50 overflow-y-auto bg-canvas-deep"
      role="dialog"
      aria-modal="true"
      aria-label="Break goal early"
    >
      <template x-if="breakGoal">
        <div class="mx-auto flex min-h-full w-full max-w-md flex-col px-5 pb-[calc(1.5rem+env(safe-area-inset-bottom))] pt-12">
          <h2 class="font-display text-3xl font-semibold tracking-tight text-cream">
            Break “<span x-text="breakGoal.name"></span>” early?
          </h2>

          <div class="mt-7 space-y-4">
            <div class="paper-dark p-5" style="border-color: rgba(224,120,86,0.3)">
              <p class="font-display leading-none">
                <span class="text-6xl font-bold text-brick-bright" x-text="$store.sl.daysLeft(breakGoal)"></span>
                <span class="text-xl font-light text-cream-2" x-text="$store.sl.daysLeft(breakGoal) === 1 ? ' day' : ' days'"></span>
              </p>
              <p class="mt-2 text-sm font-light leading-relaxed text-cream-2">
                still to go until <span class="text-cream" x-text="$store.sl.dateShort(breakGoal.date)"></span>. You'd be quitting with
                <span class="font-semibold text-cream" x-text="$store.sl.money(breakGoal.saved) + ' of ' + $store.sl.money(breakGoal.target)"></span>
                (<span x-text="Math.round($store.sl.progress(breakGoal) * 100) + '%'"></span>) on the board.
              </p>
            </div>

            <div x-show="$store.sl.streak.count > 0" class="paper-dark p-5" style="border-color: rgba(224,120,86,0.3)">
              <p class="font-semibold text-brick-bright">
                Your <span x-text="$store.sl.streak.count"></span>-day streak resets to zero.
              </p>
              <p class="mt-1 text-sm font-light leading-relaxed text-cream-2">
                Every one of those days, you held the line. Breaking the lock erases that record.
              </p>
            </div>

            <p class="px-1 text-sm font-light leading-relaxed text-cream-2">
              No money moves. It never left your real account. This only records that you didn't wait.
              If something urgent came up, that's a fair call. If it's just an itch, close this screen.
            </p>
          </div>

          <div class="mt-auto pt-9">
            <label class="block text-sm font-medium text-cream-2" for="break-confirm">
              Type <span class="font-mono font-bold text-cream">YES</span> to break the lock
            </label>
            <input
              id="break-confirm"
              x-model="breakText"
              type="text"
              autocomplete="off"
              autocapitalize="characters"
              spellcheck="false"
              class="mt-1.5 min-h-12 w-full rounded-xl border border-charcoal-2 bg-charcoal px-4 text-base text-cream outline-none focus:border-brick"
            />
            <div class="mt-4 flex flex-col gap-3">
              <button
                type="button"
                @click="breakId = null; breakText = ''"
                class="pressable min-h-13 rounded-xl bg-paper font-semibold text-ink shadow-[0_3px_0_rgba(0,0,0,0.5)]"
              >
                Keep waiting
              </button>
              <button
                type="button"
                @click="confirmBreak"
                :disabled="breakText.trim() !== 'YES'"
                class="pressable min-h-13 rounded-xl border border-brick/50 font-semibold text-brick-bright disabled:opacity-35"
              >
                Break it
              </button>
            </div>
          </div>
        </div>
      </template>
    </div>
  </main>
</Layout>
