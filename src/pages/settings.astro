---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<Layout title="SaveLock: Settings" tab="settings">
  <main x-data="settingsPage" class="mx-auto w-full max-w-md px-5 pb-44 pt-7">
    <h1 class="mb-7 px-1 font-display text-xl font-semibold tracking-tight text-cream">Settings</h1>

    <div class="space-y-5">
      <!-- Account / cloud sync -->
      <a
        href={`${base}/account/`}
        class="paper pressable relative flex rotate-[-0.4deg] items-center justify-between p-5"
      >
        <div>
          <h2 class="font-display text-lg font-semibold text-ink">Account &amp; sync</h2>
          <p x-show="$store.auth.cloudConfigured" x-cloak class="mt-1 text-sm font-light text-ink-2">
            Manage your signed-in account and sync status.
          </p>
          <p x-show="!$store.auth.cloudConfigured" x-cloak class="mt-1 text-sm font-light text-ink-2">
            Sign in to sync across devices and back up off this phone.
          </p>
        </div>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-ink-3">
          <path d="M9 6l6 6-6 6" />
        </svg>
      </a>

      <!-- Badges & challenges -->
      <a
        href={`${base}/badges/`}
        class="paper pressable relative flex rotate-[0.5deg] items-center justify-between p-5"
      >
        <div>
          <h2 class="font-display text-lg font-semibold text-ink">Badges &amp; challenges</h2>
          <p class="mt-1 text-sm font-light text-ink-2">Streaks, milestones, and an optional weekly save target.</p>
        </div>
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-ink-3">
          <path d="M9 6l6 6-6 6" />
        </svg>
      </a>

      <!-- Daily limit -->
      <section class="paper rotate-[-0.8deg] p-5">
        <h2 class="font-display text-lg font-semibold text-ink">Daily limit</h2>
        <p class="mt-1 text-sm font-light text-ink-2">
          Applies from now on. Days already ended keep the limit they were judged against.
        </p>
        <form class="mt-3 flex gap-3" @submit.prevent="saveLimit">
          <label class="sr-only" for="set-limit">Daily limit</label>
          <input
            id="set-limit"
            x-model="limitInput"
            type="number"
            inputmode="decimal"
            min="1"
            step="any"
            placeholder="500"
            class="min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
          />
          <button
            type="submit"
            class="pressable min-h-12 shrink-0 rounded-xl bg-ink px-5 font-semibold text-cream shadow-[0_3px_0_rgba(0,0,0,0.4)]"
          >
            Save
          </button>
        </form>
      </section>

      <!-- Currency label -->
      <section class="paper ml-3 rotate-[0.6deg] p-5">
        <h2 class="font-display text-lg font-semibold text-ink">Currency label</h2>
        <p class="mt-1 text-sm font-light text-ink-2">
          Just a label on the numbers. Nothing is converted.
        </p>
        <form class="mt-3 flex gap-3" @submit.prevent="saveCurrency">
          <label class="sr-only" for="set-currency">Currency label</label>
          <input
            id="set-currency"
            x-model="currencyInput"
            type="text"
            maxlength="6"
            placeholder="KSh"
            class="min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
          />
          <button
            type="submit"
            class="pressable min-h-12 shrink-0 rounded-xl bg-ink px-5 font-semibold text-cream shadow-[0_3px_0_rgba(0,0,0,0.4)]"
          >
            Save
          </button>
        </form>
      </section>

      <!-- SMS auto-detection (native Android shell only) -->
      <section x-show="native" x-cloak class="paper mr-3 rotate-[-0.4deg] p-5">
        <h2 class="font-display text-lg font-semibold text-ink">Auto-detect M-Pesa transactions</h2>
        <p class="mt-1 text-sm font-light leading-relaxed text-ink-2">
          When it's on, SaveLock reads only M-Pesa confirmation texts on this phone, nothing
          else, to log spends and notify you within seconds. It never reads your other
          messages, and no message content leaves this device.
        </p>

        <template x-if="!smsGranted && !smsDenied">
          <button
            type="button"
            @click="enableSmsDetection"
            class="pressable mt-3 min-h-12 w-full rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)]"
          >
            Turn on
          </button>
        </template>

        <template x-if="smsDenied">
          <p class="mt-3 text-sm font-medium text-brick">
            Permission was denied. Enable it from your phone's Settings → Apps → SaveLock → Permissions to use auto-detect.
          </p>
        </template>

        <template x-if="smsGranted">
          <div class="mt-4 space-y-3 border-t border-dashed border-paper-line pt-4">
            <label class="flex min-h-11 cursor-pointer items-center justify-between gap-3">
              <span class="text-sm font-medium text-ink">Notify on spend</span>
              <button
                type="button"
                role="switch"
                :aria-checked="$store.sl.settings.smsNotifySpend"
                @click="toggleSmsNotifySpend"
                class="pressable relative h-7 w-12 shrink-0 rounded-full transition-colors"
                :class="$store.sl.settings.smsNotifySpend ? 'bg-ochre' : 'bg-paper-line'"
              >
                <span
                  class="absolute top-1 h-5 w-5 rounded-full bg-paper shadow transition-transform"
                  :class="$store.sl.settings.smsNotifySpend ? 'translate-x-6' : 'translate-x-1'"
                ></span>
              </button>
            </label>
            <label class="flex min-h-11 cursor-pointer items-center justify-between gap-3">
              <span class="text-sm font-medium text-ink">Notify on money received</span>
              <button
                type="button"
                role="switch"
                :aria-checked="$store.sl.settings.smsNotifyReceived"
                @click="toggleSmsNotifyReceived"
                class="pressable relative h-7 w-12 shrink-0 rounded-full transition-colors"
                :class="$store.sl.settings.smsNotifyReceived ? 'bg-ochre' : 'bg-paper-line'"
              >
                <span
                  class="absolute top-1 h-5 w-5 rounded-full bg-paper shadow transition-transform"
                  :class="$store.sl.settings.smsNotifyReceived ? 'translate-x-6' : 'translate-x-1'"
                ></span>
              </button>
            </label>
            <p class="text-xs font-light text-ink-3">
              Transactions are always logged silently in the background. These only control whether a notification pops up.
            </p>

            <div class="border-t border-dashed border-paper-line pt-3">
              <p class="text-sm font-medium text-ink">Spend notifications</p>
              <div class="mt-2 flex gap-1 rounded-full bg-paper-deep p-1">
                <button
                  type="button"
                  @click="setSmsNotifyMode('always')"
                  class="pressable flex-1 rounded-full py-2 text-xs font-semibold"
                  :class="$store.sl.settings.smsNotifyMode === 'always' ? 'bg-paper text-ink shadow-sm' : 'text-ink-3'"
                >
                  Every transaction
                </button>
                <button
                  type="button"
                  @click="setSmsNotifyMode('importantOnly')"
                  class="pressable flex-1 rounded-full py-2 text-xs font-semibold"
                  :class="$store.sl.settings.smsNotifyMode === 'importantOnly' ? 'bg-paper text-ink shadow-sm' : 'text-ink-3'"
                >
                  Over-budget only
                </button>
              </div>
            </div>
          </div>
        </template>
      </section>

      <!-- Reminders (native Android shell only — scheduled via the OS, no server) -->
      <section x-show="native" x-cloak class="paper ml-3 rotate-[0.3deg] p-5">
        <h2 class="font-display text-lg font-semibold text-ink">Reminders</h2>
        <p class="mt-1 text-sm font-light leading-relaxed text-ink-2">
          Scheduled on this device. A weekly summary can only be as fresh as the last time
          you opened the app that week.
        </p>

        <div class="mt-4 space-y-4">
          <div>
            <label class="flex min-h-11 cursor-pointer items-center justify-between gap-3">
              <span class="text-sm font-medium text-ink">Morning reminder</span>
              <button
                type="button"
                role="switch"
                :aria-checked="$store.sl.settings.reminderMorningEnabled"
                @click="toggleMorningReminder"
                class="pressable relative h-7 w-12 shrink-0 rounded-full transition-colors"
                :class="$store.sl.settings.reminderMorningEnabled ? 'bg-ochre' : 'bg-paper-line'"
              >
                <span
                  class="absolute top-1 h-5 w-5 rounded-full bg-paper shadow transition-transform"
                  :class="$store.sl.settings.reminderMorningEnabled ? 'translate-x-6' : 'translate-x-1'"
                ></span>
              </button>
            </label>
            <input
              x-show="$store.sl.settings.reminderMorningEnabled"
              x-cloak
              x-model="$store.sl.settings.reminderMorningTime"
              @change="saveReminderTimes"
              type="time"
              class="mt-2 min-h-11 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none focus:border-ochre-soft"
            />
          </div>

          <div>
            <label class="flex min-h-11 cursor-pointer items-center justify-between gap-3">
              <span class="text-sm font-medium text-ink">Evening reminder</span>
              <button
                type="button"
                role="switch"
                :aria-checked="$store.sl.settings.reminderEveningEnabled"
                @click="toggleEveningReminder"
                class="pressable relative h-7 w-12 shrink-0 rounded-full transition-colors"
                :class="$store.sl.settings.reminderEveningEnabled ? 'bg-ochre' : 'bg-paper-line'"
              >
                <span
                  class="absolute top-1 h-5 w-5 rounded-full bg-paper shadow transition-transform"
                  :class="$store.sl.settings.reminderEveningEnabled ? 'translate-x-6' : 'translate-x-1'"
                ></span>
              </button>
            </label>
            <input
              x-show="$store.sl.settings.reminderEveningEnabled"
              x-cloak
              x-model="$store.sl.settings.reminderEveningTime"
              @change="saveReminderTimes"
              type="time"
              class="mt-2 min-h-11 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none focus:border-ochre-soft"
            />
          </div>

          <label class="flex min-h-11 cursor-pointer items-center justify-between gap-3 border-t border-dashed border-paper-line pt-3">
            <span class="text-sm font-medium text-ink">Weekly summary (Sunday evening)</span>
            <button
              type="button"
              role="switch"
              :aria-checked="$store.sl.settings.weeklySummaryEnabled"
              @click="toggleWeeklySummary"
              class="pressable relative h-7 w-12 shrink-0 rounded-full transition-colors"
              :class="$store.sl.settings.weeklySummaryEnabled ? 'bg-ochre' : 'bg-paper-line'"
            >
              <span
                class="absolute top-1 h-5 w-5 rounded-full bg-paper shadow transition-transform"
                :class="$store.sl.settings.weeklySummaryEnabled ? 'translate-x-6' : 'translate-x-1'"
              ></span>
            </button>
          </label>
        </div>
      </section>

      <!-- Deep SMS reconciliation (native Android shell only — opt-in, off by default) -->
      <section x-show="native" x-cloak class="paper ml-2 rotate-[0.4deg] p-5">
        <h2 class="font-display text-lg font-semibold text-ink">Deep SMS reconciliation</h2>
        <p class="mt-1 text-sm font-light leading-relaxed text-ink-2">
          Off by default. When on, SaveLock reads M-Pesa messages already sitting in your SMS
          inbox, once a day, to double check the always-on auto-detect above did not miss
          anything. This needs a broader permission than auto-detect uses (full inbox read
          access, not just new messages as they arrive), though it still only ever looks at
          M-Pesa sender messages, never anything else.
        </p>

        <label class="mt-3 flex min-h-11 cursor-pointer items-center justify-between gap-3">
          <span class="text-sm font-medium text-ink">Enable deep reconciliation</span>
          <button
            type="button"
            role="switch"
            :aria-checked="$store.sl.settings.deepReconciliationEnabled"
            @click="toggleDeepReconciliation"
            class="pressable relative h-7 w-12 shrink-0 rounded-full transition-colors"
            :class="$store.sl.settings.deepReconciliationEnabled ? 'bg-ochre' : 'bg-paper-line'"
          >
            <span
              class="absolute top-1 h-5 w-5 rounded-full bg-paper shadow transition-transform"
              :class="$store.sl.settings.deepReconciliationEnabled ? 'translate-x-6' : 'translate-x-1'"
            ></span>
          </button>
        </label>

        <template x-if="$store.sl.settings.deepReconciliationEnabled">
          <div class="mt-3 border-t border-dashed border-paper-line pt-3">
            <template x-if="reconciliationPermState !== 'granted'">
              <div>
                <p class="text-xs font-light text-ink-2">Inbox read permission not yet granted.</p>
                <button
                  type="button"
                  @click="grantDeepReconciliation"
                  class="pressable mt-2 min-h-11 w-full rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)]"
                >
                  Grant permission
                </button>
              </div>
            </template>
            <button
              type="button"
              x-show="reconciliationPermState === 'granted'"
              @click="checkReconciliationNow"
              class="chip pressable min-h-11 w-full rounded-xl text-sm font-semibold text-ink"
            >
              Check now
            </button>
          </div>
        </template>
      </section>

      <!-- Categories -->
      <section class="paper mr-2 rotate-[-0.3deg] p-5">
        <h2 class="font-display text-lg font-semibold text-ink">Categories</h2>
        <p class="mt-1 text-sm font-light text-ink-2">Used to tag spends and build the "Where it went" breakdown.</p>

        <ul class="mt-3 space-y-2">
          <template x-for="c in $store.sl.settings.categories" :key="c">
            <li class="flex items-center gap-2">
              <template x-if="renamingCategory === c">
                <form @submit.prevent="submitRename" class="flex flex-1 gap-2">
                  <input
                    x-model="renameInput"
                    type="text"
                    maxlength="24"
                    class="min-h-11 w-full rounded-xl border border-paper-line bg-paper-deep px-3 text-sm text-ink outline-none focus:border-ochre-soft"
                  />
                  <button type="submit" class="chip pressable min-h-11 shrink-0 rounded-xl px-3 text-sm font-semibold text-ink">Save</button>
                </form>
              </template>
              <template x-if="renamingCategory !== c">
                <button
                  type="button"
                  @click="startRename(c)"
                  class="chip pressable min-h-11 flex-1 rounded-xl px-4 text-left text-sm font-semibold text-ink"
                  x-text="c"
                ></button>
              </template>
              <button
                type="button"
                x-show="c !== 'Other'"
                @click="removeCategory(c)"
                class="pressable flex h-11 w-11 shrink-0 items-center justify-center rounded-xl text-ink-3 active:text-brick"
                :aria-label="'Remove ' + c"
              >
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M4 7h16M10 11v6M14 11v6M6 7l1 13h10l1-13M9 7V4h6v3" />
                </svg>
              </button>
            </li>
          </template>
        </ul>

        <form class="mt-3 flex gap-2" @submit.prevent="addCategory">
          <label class="sr-only" for="new-category">New category</label>
          <input
            id="new-category"
            x-model="newCategory"
            type="text"
            maxlength="24"
            placeholder="Add a category…"
            class="min-h-11 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-sm text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
          />
          <button type="submit" class="chip pressable min-h-11 shrink-0 rounded-xl px-4 text-sm font-semibold text-ink">Add</button>
        </form>
      </section>

      <!-- Backup -->
      <section class="paper mr-3 rotate-[-0.5deg] p-5">
        <h2 class="font-display text-lg font-semibold text-ink">Backup</h2>
        <p x-show="$store.auth.cloudConfigured" x-cloak class="mt-1 text-sm font-light leading-relaxed text-ink-2">
          Your account already backs this up, but you can still export a local file as an extra
          copy, or use it to move data to a new device before signing in there.
        </p>
        <p x-show="!$store.auth.cloudConfigured" x-cloak class="mt-1 text-sm font-light leading-relaxed text-ink-2">
          Everything lives only on this device. Export a file before clearing your browser
          or switching phones. Import it to pick up where you left off.
        </p>
        <div class="mt-3 flex gap-3">
          <button
            type="button"
            @click="exportBackup"
            class="chip pressable min-h-12 flex-1 rounded-xl font-semibold text-ink"
          >
            Export
          </button>
          <label class="chip pressable flex min-h-12 flex-1 cursor-pointer items-center justify-center rounded-xl font-semibold text-ink">
            Import
            <input type="file" accept="application/json,.json" class="hidden" @change="importBackup($event)" />
          </label>
        </div>
        <p x-show="importError" x-cloak class="mt-3 text-sm font-medium text-brick" x-text="'⚠ ' + importError"></p>
        <p x-show="importOk" x-cloak class="mt-3 flex items-center gap-1.5 text-sm font-medium text-ochre-deep">
          <span x-html="$handCheck()"></span> Backup restored. Reloading…
        </p>
      </section>

      <!-- Streak card style: TEMPORARY developer only comparison toggle,
           meant to be removed once a direction is chosen, not a permanent
           setting. -->
      <section class="paper rotate-[0.3deg] p-5" style="border: 2px dashed rgba(180,69,47,0.4)">
        <h2 class="font-display text-lg font-semibold text-ink">Streak card style</h2>
        <p class="mt-1 text-sm font-light leading-relaxed text-ink-2">
          Developer setting for comparing two looks while one is chosen. Remove this before
          shipping.
        </p>
        <div class="mt-3 flex gap-1 rounded-full bg-paper-deep p-0.5">
          <button
            type="button"
            @click="$store.sl.setStreakTreatment('hand')"
            class="pressable min-h-10 flex-1 rounded-full text-sm font-semibold"
            :class="$store.sl.settings.streakTreatment === 'hand' ? 'bg-paper text-ink shadow-sm' : 'text-ink-3'"
          >
            Sketched
          </button>
          <button
            type="button"
            @click="$store.sl.setStreakTreatment('fire')"
            class="pressable min-h-10 flex-1 rounded-full text-sm font-semibold"
            :class="$store.sl.settings.streakTreatment === 'fire' ? 'bg-paper text-ink shadow-sm' : 'text-ink-3'"
          >
            Gamified
          </button>
        </div>
      </section>

      <!-- Erase -->
      <section class="paper ml-2 rotate-[0.4deg] p-5">
        <h2 class="font-display text-lg font-semibold text-ink">Start over</h2>
        <p x-show="$store.auth.cloudConfigured" x-cloak class="mt-1 text-sm font-light text-ink-2">
          Erases the limit, streak, goals and history on this device and in your account, since
          the two stay in sync. There is no undo. Export a backup first if in doubt.
        </p>
        <p x-show="!$store.auth.cloudConfigured" x-cloak class="mt-1 text-sm font-light text-ink-2">
          Erases the limit, streak, goals and history on this device. There is no undo.
          Export a backup first if in doubt.
        </p>
        <button
          type="button"
          @click="erase"
          class="pressable mt-3 min-h-12 w-full rounded-xl border font-semibold transition-colors"
          :class="eraseArmed
            ? 'border-brick bg-brick text-cream'
            : 'border-brick/40 text-brick'"
          x-text="eraseArmed ? 'Tap again to erase everything' : 'Erase all data'"
        ></button>
      </section>

      <!-- About -->
      <section class="px-2 pt-2 text-xs font-light leading-relaxed text-cream-2">
        <p x-show="$store.auth.cloudConfigured" x-cloak>
          SaveLock is a discipline layer, not a wallet. It holds no money and connects to no
          bank. The real cash stays wherever you locked it, this app just keeps score while
          you wait. Signing in keeps your own allowance, spends, goals, and streak backed up to
          your account, never anything else, and never with anyone but you.
        </p>
        <p x-show="!$store.auth.cloudConfigured" x-cloak>
          SaveLock is a discipline layer, not a wallet. It holds no money and connects to no
          bank. The real cash stays wherever you locked it, this app just keeps score while
          you wait. Everything stays on this device unless you choose to sign in above, signing
          in only syncs your own allowance, spends, goals, and streak to your account, never
          anything else, and never with anyone but you.
        </p>
      </section>
    </div>
  </main>
</Layout>
