---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SaveLock — Settings" tab="settings">
  <main x-data="settingsPage" class="mx-auto w-full max-w-md px-5 pb-36 pt-8">
    <h1 class="mb-6 text-lg font-semibold tracking-tight">Settings</h1>

    <div class="space-y-4">
      <!-- Daily limit -->
      <section class="rounded-2xl border border-stone-200 bg-white p-5 dark:border-stone-800 dark:bg-stone-900">
        <h2 class="font-semibold">Daily limit</h2>
        <p class="mt-1 text-sm text-stone-500 dark:text-stone-400">
          Applies from now on. Days already ended keep the limit they were judged against.
        </p>
        <form class="mt-3 flex gap-3" @submit.prevent="saveLimit">
          <label class="sr-only" for="set-limit">Daily limit</label>
          <input
            id="set-limit"
            x-model="limitInput"
            type="number"
            inputmode="decimal"
            min="1"
            step="any"
            placeholder="500"
            class="min-h-12 w-full rounded-xl border border-stone-300 bg-white px-4 text-base outline-none focus:border-teal-600 dark:border-stone-700 dark:bg-stone-950 dark:focus:border-teal-400"
          />
          <button
            type="submit"
            class="min-h-12 shrink-0 rounded-xl bg-teal-700 px-5 font-semibold text-white active:bg-teal-800 dark:bg-teal-500 dark:text-stone-950 dark:active:bg-teal-400"
          >
            Save
          </button>
        </form>
      </section>

      <!-- Currency label -->
      <section class="rounded-2xl border border-stone-200 bg-white p-5 dark:border-stone-800 dark:bg-stone-900">
        <h2 class="font-semibold">Currency label</h2>
        <p class="mt-1 text-sm text-stone-500 dark:text-stone-400">
          Just a label on the numbers — nothing is converted.
        </p>
        <form class="mt-3 flex gap-3" @submit.prevent="saveCurrency">
          <label class="sr-only" for="set-currency">Currency label</label>
          <input
            id="set-currency"
            x-model="currencyInput"
            type="text"
            maxlength="6"
            placeholder="KSh"
            class="min-h-12 w-full rounded-xl border border-stone-300 bg-white px-4 text-base outline-none focus:border-teal-600 dark:border-stone-700 dark:bg-stone-950 dark:focus:border-teal-400"
          />
          <button
            type="submit"
            class="min-h-12 shrink-0 rounded-xl bg-teal-700 px-5 font-semibold text-white active:bg-teal-800 dark:bg-teal-500 dark:text-stone-950 dark:active:bg-teal-400"
          >
            Save
          </button>
        </form>
      </section>

      <!-- Backup -->
      <section class="rounded-2xl border border-stone-200 bg-white p-5 dark:border-stone-800 dark:bg-stone-900">
        <h2 class="font-semibold">Backup</h2>
        <p class="mt-1 text-sm leading-relaxed text-stone-500 dark:text-stone-400">
          Everything lives only on this device. Export a file before clearing your browser
          or switching phones — import it to pick up where you left off.
        </p>
        <div class="mt-3 flex gap-3">
          <button
            type="button"
            @click="exportBackup"
            class="min-h-12 flex-1 rounded-xl border border-stone-300 font-semibold text-stone-700 active:bg-stone-100 dark:border-stone-700 dark:text-stone-200 dark:active:bg-stone-800"
          >
            Export
          </button>
          <label
            class="flex min-h-12 flex-1 cursor-pointer items-center justify-center rounded-xl border border-stone-300 font-semibold text-stone-700 active:bg-stone-100 dark:border-stone-700 dark:text-stone-200 dark:active:bg-stone-800"
          >
            Import
            <input type="file" accept="application/json,.json" class="hidden" @change="importBackup($event)" />
          </label>
        </div>
        <p x-show="importError" x-cloak class="mt-3 text-sm font-medium text-rose-600 dark:text-rose-400" x-text="'⚠ ' + importError"></p>
        <p x-show="importOk" x-cloak class="mt-3 text-sm font-medium text-teal-700 dark:text-teal-400">
          ✓ Backup restored. Reloading…
        </p>
      </section>

      <!-- Erase -->
      <section class="rounded-2xl border border-stone-200 bg-white p-5 dark:border-stone-800 dark:bg-stone-900">
        <h2 class="font-semibold">Start over</h2>
        <p class="mt-1 text-sm text-stone-500 dark:text-stone-400">
          Erases the limit, streak, goals and history on this device. There is no undo —
          export a backup first if in doubt.
        </p>
        <button
          type="button"
          @click="erase"
          class="mt-3 min-h-12 w-full rounded-xl border font-semibold transition-colors"
          :class="eraseArmed
            ? 'border-rose-500 bg-rose-600 text-white'
            : 'border-rose-300 text-rose-600 dark:border-rose-900 dark:text-rose-400'"
          x-text="eraseArmed ? 'Tap again to erase everything' : 'Erase all data'"
        ></button>
      </section>

      <!-- About -->
      <section class="px-1 pt-2 text-xs leading-relaxed text-stone-400 dark:text-stone-500">
        <p>
          SaveLock is a discipline layer, not a wallet. It holds no money, connects to no
          bank, and sends nothing off this device. The real cash stays wherever you locked
          it — this app just keeps score while you wait.
        </p>
      </section>
    </div>
  </main>
</Layout>
