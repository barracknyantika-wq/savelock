---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SaveLock: Groups" tab="challenges">
  <main x-data="challengesPage" class="mx-auto w-full max-w-md px-5 pb-44 pt-7">
    <template x-if="!cloudConfigured">
      <p class="mt-16 rotate-[-1deg] rounded-2xl border border-dashed border-charcoal-2 px-6 py-7 text-center text-sm leading-relaxed text-cream-2">
        Group challenges need an account, so friends can actually share one. This build has no account sync configured.
      </p>
    </template>

    <template x-if="cloudConfigured">
      <div>
        <header class="mb-2 flex items-center justify-between px-1">
          <h1 class="font-display text-xl font-semibold tracking-tight text-cream">Groups</h1>
          <div class="flex items-center gap-2">
            <button
              type="button"
              @click="openJoin"
              class="chip pressable min-h-11 rounded-full px-4 text-sm font-semibold text-ink"
            >
              Join
            </button>
            <button
              type="button"
              @click="openNew"
              class="pressable min-h-11 rounded-full bg-ochre px-5 text-sm font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)]"
            >
              New
            </button>
          </div>
        </header>

        <p class="mb-7 px-1 text-xs font-light leading-relaxed text-cream-2">
          A shared streak with friends, not shared money. Everyone keeps saving in their own real
          account. The group only breaks its streak if someone misses a check in.
        </p>

        <p x-show="loading" x-cloak class="px-1 text-sm font-light text-cream-2">Loading…</p>

        <p
          x-show="!loading && !challenges.length"
          x-cloak
          class="rotate-[-1deg] rounded-2xl border border-dashed border-charcoal-2 px-6 py-7 text-center text-sm leading-relaxed text-cream-2"
        >
          No groups yet. Start one and share the code, or join a friend's with theirs.
        </p>

        <div x-show="!loading && challenges.length" x-cloak class="space-y-4">
          <template x-for="(c, ci) in challenges" :key="c.id">
            <button
              type="button"
              @click="openDetail(c.id)"
              class="paper pressable block w-full p-5 text-left"
              :class="ci % 2 === 0 ? 'rotate-[-1deg] mr-3' : 'rotate-[0.8deg] ml-3'"
            >
              <div class="flex items-start justify-between gap-3">
                <div class="min-w-0">
                  <h2 class="truncate font-display text-lg font-semibold tracking-tight text-ink" x-text="c.name"></h2>
                  <p class="mt-0.5 text-sm font-light text-ink-2">
                    <span x-text="$store.sl.money(c.targetAmount)"></span>
                    <span x-text="c.cadence === 'daily' ? ' per day' : ' per week'"></span>
                  </p>
                </div>
                <span
                  class="shrink-0 rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-wider"
                  :class="c.status === 'active' ? 'bg-ochre/15 text-ochre-deep' : 'bg-paper-deep text-ink-3'"
                  x-text="c.status === 'active' ? 'Active' : 'Ended'"
                ></span>
              </div>
              <p class="mt-3 text-xs font-light text-ink-3">
                Code <span class="font-mono font-semibold tracking-wider text-ink-2" x-text="c.joinCode"></span>
              </p>
            </button>
          </template>
        </div>
      </div>
    </template>

    <!-- New group sheet: form, then the created code screen -->
    <div x-show="newSheet" x-cloak class="fixed inset-0 z-50" role="dialog" aria-modal="true" aria-label="New group challenge">
      <div class="absolute inset-0 bg-black/60" x-show="newSheet" x-transition.opacity.duration.150ms @click="!createdChallenge && (newSheet = false)"></div>
      <div
        x-show="newSheet"
        x-transition:enter="transition duration-200 ease-out"
        x-transition:enter-start="translate-y-full"
        x-transition:enter-end="translate-y-0"
        x-transition:leave="transition duration-150 ease-in"
        x-transition:leave-start="translate-y-0"
        x-transition:leave-end="translate-y-full"
        class="paper absolute inset-x-0 bottom-0 rounded-b-none rounded-t-3xl p-5 pb-[calc(1.5rem+env(safe-area-inset-bottom))]"
      >
        <div class="mx-auto max-w-md">
          <div class="mx-auto mb-3 h-1.5 w-10 rounded-full bg-paper-line" aria-hidden="true"></div>

          <template x-if="!createdChallenge">
            <form @submit.prevent="submitNew">
              <h3 class="font-display text-xl font-semibold tracking-tight">New group challenge</h3>
              <p class="mt-1 text-xs font-light text-ink-2">
                Everyone who joins keeps their own money in their own account. This only tracks who
                showed up.
              </p>
              <label class="mt-4 block text-sm font-medium text-ink-2" for="c-name">Name</label>
              <input
                id="c-name"
                x-model="cName"
                type="text"
                maxlength="40"
                required
                placeholder="No takeout this month"
                class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
              />
              <label class="mt-3 block text-sm font-medium text-ink-2" for="c-target">Target amount per period</label>
              <input
                id="c-target"
                x-model="cTarget"
                type="number"
                inputmode="decimal"
                min="1"
                step="any"
                required
                placeholder="500"
                class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
              />
              <label class="mt-3 block text-sm font-medium text-ink-2">How often</label>
              <div class="mt-1 flex gap-1 rounded-full bg-paper-deep p-0.5">
                <button
                  type="button"
                  @click="cCadence = 'daily'"
                  class="pressable min-h-10 flex-1 rounded-full text-sm font-semibold"
                  :class="cCadence === 'daily' ? 'bg-paper text-ink shadow-sm' : 'text-ink-3'"
                >
                  Daily
                </button>
                <button
                  type="button"
                  @click="cCadence = 'weekly'"
                  class="pressable min-h-10 flex-1 rounded-full text-sm font-semibold"
                  :class="cCadence === 'weekly' ? 'bg-paper text-ink shadow-sm' : 'text-ink-3'"
                >
                  Weekly
                </button>
              </div>
              <div class="mt-5 flex gap-3">
                <button type="button" @click="newSheet = false" class="pressable min-h-12 flex-1 rounded-xl border border-paper-line font-semibold text-ink-2">
                  Cancel
                </button>
                <button
                  type="submit"
                  :disabled="createBusy"
                  class="pressable min-h-12 flex-1 rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)] disabled:opacity-50"
                >
                  <span x-text="createBusy ? 'Creating…' : 'Create'"></span>
                </button>
              </div>
            </form>
          </template>

          <template x-if="createdChallenge">
            <div class="py-2 text-center">
              <div class="animate-stamp-in mx-auto h-20 w-20" x-html="$handCheck()"></div>
              <h3 class="mt-2 font-display text-xl font-semibold tracking-tight" x-text="'“' + createdChallenge.name + '” is ready'"></h3>
              <p class="mt-2 text-sm font-light leading-relaxed text-ink-2">
                Share this code with whoever is joining you. Anyone with it can join until you end the
                challenge.
              </p>
              <p class="mt-4 rounded-2xl border-2 border-dashed border-ochre-soft bg-ochre/10 py-4 font-mono text-3xl font-bold tracking-[0.3em] text-ochre-deep" x-text="createdChallenge.joinCode"></p>
              <div class="mt-4 flex gap-3">
                <button
                  type="button"
                  @click="copyJoinCode(createdChallenge.joinCode)"
                  class="chip pressable min-h-12 flex-1 rounded-xl text-sm font-semibold text-ink"
                >
                  Copy code
                </button>
                <button
                  type="button"
                  @click="shareJoinCode(createdChallenge.joinCode, createdChallenge.name)"
                  class="chip pressable min-h-12 flex-1 rounded-xl text-sm font-semibold text-ink"
                >
                  Share
                </button>
              </div>
              <button
                type="button"
                @click="closeNewSheet(); openDetail(createdChallenge.id)"
                class="pressable mt-5 min-h-11 w-full rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)]"
              >
                Done
              </button>
            </div>
          </template>
        </div>
      </div>
    </div>

    <!-- Join by code sheet -->
    <div x-show="joinSheet" x-cloak class="fixed inset-0 z-50" role="dialog" aria-modal="true" aria-label="Join a group challenge">
      <div class="absolute inset-0 bg-black/60" x-show="joinSheet" x-transition.opacity.duration.150ms @click="joinSheet = false"></div>
      <form
        @submit.prevent="submitJoin"
        x-show="joinSheet"
        x-transition:enter="transition duration-200 ease-out"
        x-transition:enter-start="translate-y-full"
        x-transition:enter-end="translate-y-0"
        x-transition:leave="transition duration-150 ease-in"
        x-transition:leave-start="translate-y-0"
        x-transition:leave-end="translate-y-full"
        class="paper absolute inset-x-0 bottom-0 rounded-b-none rounded-t-3xl p-5 pb-[calc(1.5rem+env(safe-area-inset-bottom))]"
      >
        <div class="mx-auto max-w-md">
          <div class="mx-auto mb-3 h-1.5 w-10 rounded-full bg-paper-line" aria-hidden="true"></div>
          <h3 class="font-display text-xl font-semibold tracking-tight">Join a group</h3>
          <p class="mt-1 text-xs font-light text-ink-2">Enter the code whoever started it shared with you.</p>
          <label class="mt-4 block text-sm font-medium text-ink-2" for="join-code">Code</label>
          <input
            id="join-code"
            x-model="joinCode"
            type="text"
            maxlength="6"
            autocomplete="off"
            autocapitalize="characters"
            spellcheck="false"
            required
            placeholder="ABC123"
            class="mt-1 min-h-14 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-center font-mono text-2xl font-bold uppercase tracking-[0.3em] text-ink outline-none placeholder:text-ink-3 placeholder:tracking-[0.3em] focus:border-ochre-soft"
          />
          <p x-show="joinError" x-cloak class="mt-2 text-sm font-medium text-brick" x-text="joinError"></p>
          <div class="mt-5 flex gap-3">
            <button type="button" @click="joinSheet = false" class="pressable min-h-12 flex-1 rounded-xl border border-paper-line font-semibold text-ink-2">
              Cancel
            </button>
            <button
              type="submit"
              :disabled="joinBusy"
              class="pressable min-h-12 flex-1 rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)] disabled:opacity-50"
            >
              <span x-text="joinBusy ? 'Joining…' : 'Join'"></span>
            </button>
          </div>
        </div>
      </form>
    </div>

    <!-- Challenge detail: full screen, same weight as the break goal screen -->
    <div x-show="selectedId" x-cloak class="fixed inset-0 z-50 overflow-y-auto bg-canvas" role="dialog" aria-modal="true" aria-label="Group challenge">
      <template x-if="detail">
        <div class="mx-auto w-full max-w-md px-5 pb-12 pt-7">
          <button type="button" @click="closeDetail" class="pressable flex min-h-11 items-center gap-1 text-sm font-medium text-cream-2">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6" /></svg>
            Back
          </button>

          <h1 class="mt-3 font-display text-2xl font-semibold tracking-tight text-cream" x-text="detail.challenge.name"></h1>
          <p class="mt-1 text-sm font-light text-cream-2">
            <span x-text="$store.sl.money(detail.challenge.targetAmount)"></span>
            <span x-text="detail.challenge.cadence === 'daily' ? ' per day, together' : ' per week, together'"></span>
          </p>

          <!-- Shared streak, the emotional centerpiece of this screen -->
          <div class="paper mt-5 p-6 text-center" style="transform: rotate(-0.6deg)">
            <p class="font-display text-6xl font-bold tracking-tight text-ink" x-text="detail.streak"></p>
            <p class="mt-1 text-sm font-medium text-ink-2" x-text="detail.streak === 1 ? 'period the whole group held together' : 'periods the whole group held together'"></p>
            <span class="mt-1 inline-block" x-html="$squiggle()"></span>
          </div>

          <!-- This period's check in -->
          <div class="paper-dark mt-5 p-5">
            <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-cream-2">This period</h2>
            <template x-if="!myCheckedInThisPeriod">
              <div class="mt-3">
                <label class="block text-sm font-medium text-cream-2" for="checkin-amount">Amount saved, optional</label>
                <div class="mt-1.5 flex gap-3">
                  <input
                    id="checkin-amount"
                    x-model="checkinAmount"
                    type="number"
                    inputmode="decimal"
                    min="0"
                    step="any"
                    placeholder="0"
                    class="min-h-12 min-w-0 flex-1 rounded-xl border border-charcoal-2 bg-charcoal px-4 text-base text-cream outline-none placeholder:text-cream-2 focus:border-ochre-soft"
                  />
                  <button
                    type="button"
                    @click="submitCheckin"
                    :disabled="checkinBusy"
                    class="pressable min-h-12 shrink-0 whitespace-nowrap rounded-xl bg-ochre px-5 font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)] disabled:opacity-50"
                  >
                    <span x-text="checkinBusy ? 'Saving…' : 'Check in'"></span>
                  </button>
                </div>
              </div>
            </template>
            <template x-if="myCheckedInThisPeriod">
              <p class="mt-3 flex items-center gap-1.5 text-sm font-medium text-ochre">
                <span class="h-5 w-5" x-html="$handCheck()"></span>
                You're checked in for this period.
              </p>
            </template>
          </div>

          <!-- Participant list -->
          <div class="mt-5">
            <h2 class="px-1 text-xs font-semibold uppercase tracking-[0.18em] text-cream-2">
              Participants (<span x-text="detail.participants.length"></span>)
            </h2>
            <ul class="mt-2 space-y-2">
              <template x-for="p in detail.participants" :key="p.userId">
                <li class="paper-dark flex items-center justify-between gap-3 px-4 py-3">
                  <span class="min-w-0 truncate font-medium text-cream" x-text="p.name + (p.userId === detail.myUserId ? ' (you)' : '')"></span>
                  <span
                    class="shrink-0 rounded-full px-2.5 py-1 text-xs font-bold uppercase tracking-wider"
                    :class="p.checkedInThisPeriod ? 'bg-ochre/15 text-ochre-deep' : 'bg-charcoal text-cream-2'"
                    x-text="p.checkedInThisPeriod ? 'Checked in' : 'Waiting'"
                  ></span>
                </li>
              </template>
            </ul>
          </div>

          <!-- Invite more friends -->
          <div class="paper-dark mt-5 flex items-center justify-between gap-3 p-4">
            <p class="text-sm font-light text-cream-2">
              Code <span class="font-mono font-semibold tracking-wider text-cream" x-text="detail.challenge.joinCode"></span>
            </p>
            <button
              type="button"
              @click="shareJoinCode(detail.challenge.joinCode, detail.challenge.name)"
              class="chip pressable min-h-10 rounded-full px-4 text-sm font-semibold text-ink"
            >
              Invite
            </button>
          </div>
        </div>
      </template>
    </div>
  </main>
</Layout>
