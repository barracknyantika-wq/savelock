---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<Layout title="SaveLock — Badges">
  <main x-data="badgesPage" class="mx-auto w-full max-w-md px-5 pb-44 pt-7">
    <header class="mb-7 flex items-center gap-3 px-1">
      <a
        href={`${base}/settings/`}
        class="pressable flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-cream-2"
        aria-label="Back to Settings"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" />
        </svg>
      </a>
      <h1 class="font-display text-xl font-semibold tracking-tight text-cream">Badges</h1>
    </header>

    <!-- Stats strip -->
    <section class="paper relative rotate-[-0.8deg] p-5">
      <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-3">Your record</h2>
      <div class="mt-3 grid grid-cols-3 gap-3 text-center">
        <div>
          <p class="font-display text-2xl font-bold text-ink" x-text="$store.sl.streak.count"></p>
          <p class="text-[10px] uppercase tracking-wide text-ink-3">Current streak</p>
        </div>
        <div>
          <p class="font-display text-2xl font-bold text-ink" x-text="stats.longestStreak"></p>
          <p class="text-[10px] uppercase tracking-wide text-ink-3">Longest streak</p>
        </div>
        <div>
          <p class="font-display text-2xl font-bold text-ink" x-text="$store.sl.money(stats.biggestSingleDaySave)"></p>
          <p class="text-[10px] uppercase tracking-wide text-ink-3">Biggest single-day save</p>
        </div>
      </div>
    </section>

    <!-- Badge collection -->
    <section class="paper relative mt-5 ml-3 rotate-[0.5deg] p-5">
      <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-3">Collection</h2>
      <div class="mt-3 grid grid-cols-2 gap-3">
        <template x-for="b in badgeDefs" :key="b.id">
          <div
            class="rounded-2xl border p-3.5 text-left"
            :class="isEarned(b.id) ? 'border-ochre/40 bg-ochre/10' : 'border-dashed border-paper-line opacity-50'"
          >
            <p class="text-2xl" x-text="isEarned(b.id) ? '🏅' : '🔒'"></p>
            <p class="mt-1.5 font-display text-sm font-semibold text-ink" x-text="b.name"></p>
            <p class="mt-0.5 text-xs font-light leading-snug text-ink-2" x-text="b.description"></p>
            <p x-show="isEarned(b.id)" x-cloak class="mt-1.5 text-[10px] font-semibold uppercase tracking-wide text-ochre-deep">
              Earned <span x-text="earnedAt(b.id)"></span>
            </p>
          </div>
        </template>
      </div>
    </section>

    <!-- Weekly challenge (opt-in) -->
    <section class="paper relative mt-5 mr-2 rotate-[-0.3deg] p-5">
      <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-3">Weekly challenge</h2>
      <p class="mt-1 text-sm font-light leading-relaxed text-ink-2">
        Optional. Set an extra amount to save this week on top of your daily limit — no
        penalty at all if you don't hit it or don't start one.
      </p>

      <template x-if="!challenge">
        <form class="mt-3 flex gap-3" @submit.prevent="startChallenge">
          <label class="sr-only" for="challenge-target">Extra amount to save this week</label>
          <input
            id="challenge-target"
            x-model="challengeInput"
            type="number"
            inputmode="decimal"
            min="1"
            step="any"
            placeholder="e.g. 500"
            class="min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
          />
          <button
            type="submit"
            class="pressable min-h-12 shrink-0 rounded-xl bg-ochre px-5 font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)]"
          >
            Start
          </button>
        </form>
      </template>

      <template x-if="challenge">
        <div class="mt-3 rounded-xl border border-ochre/30 bg-ochre/10 p-4">
          <p class="text-sm text-ink-2">
            Saved <span class="font-semibold text-ink" x-text="$store.sl.money(challengeSavedSoFar)"></span>
            of <span class="font-semibold text-ink" x-text="$store.sl.money(challenge.targetExtra)"></span> extra —
            <span x-text="challengeDaysLeft"></span> <span x-text="challengeDaysLeft === 1 ? 'day' : 'days'"></span> left.
          </p>
          <div class="mt-2 h-2 overflow-hidden rounded-full bg-paper-deep">
            <div
              class="h-full rounded-full bg-ochre transition-[width]"
              :style="'width: ' + Math.min(100, Math.round((challengeSavedSoFar / challenge.targetExtra) * 100)) + '%'"
            ></div>
          </div>
          <button
            type="button"
            @click="cancelChallenge"
            class="pressable mt-3 min-h-11 w-full rounded-xl border border-paper-line text-sm font-medium text-ink-2"
          >
            Cancel challenge
          </button>
        </div>
      </template>

      <div x-show="challengeHistory.length" x-cloak class="mt-4 space-y-1.5 border-t border-dashed border-paper-line pt-3">
        <template x-for="c in challengeHistory.slice(0, 5)" :key="c.startDate + c.status">
          <div class="flex items-center justify-between text-xs">
            <span class="text-ink-2" x-text="$store.sl.dateShort(c.startDate) + ' → ' + $store.sl.dateShort(c.endDate)"></span>
            <span
              class="font-semibold uppercase tracking-wide"
              :class="{ passed: 'text-ochre-deep', missed: 'text-ink-3', cancelled: 'text-ink-3' }[c.status]"
              x-text="c.status"
            ></span>
          </div>
        </template>
      </div>
    </section>
  </main>
</Layout>
