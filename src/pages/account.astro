---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<Layout title="SaveLock: Account">
  <main class="mx-auto w-full max-w-md px-5 pb-44 pt-7">
    <header class="mb-7 flex items-center gap-3 px-1">
      <a
        href={`${base}/settings/`}
        class="pressable flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-cream-2"
        aria-label="Back to Settings"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" />
        </svg>
      </a>
      <h1 class="font-display text-xl font-semibold tracking-tight text-cream">Account</h1>
    </header>

    <!-- Cloud sync not built for this app -->
    <template x-if="!$store.auth.cloudConfigured">
      <section class="paper relative rotate-[-0.5deg] p-5">
        <h2 class="font-display text-lg font-semibold text-ink">Cloud sync isn't set up</h2>
        <p class="mt-2 text-sm font-light leading-relaxed text-ink-2">
          This build of SaveLock has no Supabase project connected, so everything stays local-only
          on this device. That's exactly how the app has always worked, and nothing about this
          screen changes that.
        </p>
      </section>
    </template>

    <!--
      Reached only once $store.auth.stage is 'ready': signing in, and the
      import/reconcile decision if this device had its own data, both
      happen in the mandatory gate (Layout.astro) before this page is ever
      visible, so there's nothing left to do here but show who's signed in.
    -->
    <template x-if="$store.auth.cloudConfigured">
      <div class="space-y-5">
        <section class="paper relative rotate-[-0.5deg] p-5">
          <h2 class="font-display text-lg font-semibold text-ink">
            <span x-text="$store.auth.displayName || $store.auth.identity || 'Signed in'"></span>
          </h2>
          <p x-show="$store.auth.displayName" x-cloak class="mt-1 text-sm font-light text-ink-2" x-text="$store.auth.identity"></p>
          <button
            type="button"
            @click="$store.auth.signOutOfAccount()"
            class="pressable mt-4 min-h-12 w-full rounded-xl border border-paper-line font-semibold text-ink-2"
          >
            Sign out
          </button>
        </section>

        <section class="paper relative ml-2 rotate-[0.5deg] p-5">
          <h2 class="font-display text-lg font-semibold text-ink">Your progress is saved</h2>
          <p class="mt-2 text-sm font-light leading-relaxed text-ink-2">
            Your allowance, goals, spending history, and streak are all backed up to this account
            as you go. Switching phones, reinstalling the app, or clearing your browser will not
            lose any of it.
          </p>
        </section>

        <section class="paper relative mr-2 rotate-[-0.3deg] p-5">
          <h2 class="font-display text-lg font-semibold text-ink">Getting your progress back</h2>
          <p class="mt-2 text-sm font-light leading-relaxed text-ink-2">
            <template x-if="$store.auth.signInMethod === 'phone'">
              <span
                >Sign in again with <span class="font-semibold text-ink" x-text="$store.auth.identity"></span> on
                any device to pick up exactly where you left off.</span
              >
            </template>
            <template x-if="$store.auth.signInMethod === 'google'">
              <span
                >Sign in again with the same Google account, <span class="font-semibold text-ink" x-text="$store.auth.identity"></span>, on
                any device to pick up exactly where you left off.</span
              >
            </template>
          </p>
        </section>
      </div>
    </template>
  </main>
</Layout>
