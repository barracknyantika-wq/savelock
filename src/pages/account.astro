---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/+$/, '');
---

<Layout title="SaveLock: Account">
  <main x-data="accountPage" class="mx-auto w-full max-w-md px-5 pb-44 pt-7">
    <header class="mb-7 flex items-center gap-3 px-1">
      <a
        href={`${base}/settings/`}
        class="pressable flex h-9 w-9 shrink-0 items-center justify-center rounded-full text-cream-2"
        aria-label="Back to Settings"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M15 18l-6-6 6-6" />
        </svg>
      </a>
      <h1 class="font-display text-xl font-semibold tracking-tight text-cream">Account</h1>
    </header>

    <!-- Cloud sync not built for this app -->
    <template x-if="!cloudConfigured">
      <section class="paper relative rotate-[-0.5deg] p-5">
        <h2 class="font-display text-lg font-semibold text-ink">Cloud sync isn't set up</h2>
        <p class="mt-2 text-sm font-light leading-relaxed text-ink-2">
          This build of SaveLock has no Supabase project connected, so everything stays local-only
          on this device. That's exactly how the app has always worked, and nothing about this
          screen changes that.
        </p>
      </section>
    </template>

    <template x-if="cloudConfigured">
      <div>
        <!-- Signed in -->
        <template x-if="stage === 'signed-in'">
          <section class="paper relative rotate-[-0.5deg] p-5">
            <h2 class="font-display text-lg font-semibold text-ink">Signed in</h2>
            <p class="mt-1 text-sm font-light text-ink-2" x-text="identityOnFile"></p>
            <p class="mt-3 text-xs font-light leading-relaxed text-ink-2">
              Your data syncs to your account and stays available offline on this device. Sign in
              with the same number on another device to pick up where you left off.
            </p>
            <button
              type="button"
              @click="signOutOfAccount"
              class="pressable mt-4 min-h-12 w-full rounded-xl border border-paper-line font-semibold text-ink-2"
            >
              Sign out
            </button>
          </section>
        </template>

        <!-- Phone entry -->
        <template x-if="stage === 'phone'">
          <section class="paper relative rotate-[-0.5deg] p-5">
            <h2 class="font-display text-lg font-semibold text-ink">Sign in</h2>
            <p class="mt-1 text-sm font-light leading-relaxed text-ink-2">
              Sync your allowance, goals, and streak across devices. This app holds no money.
              Signing in only lets your own tracking data follow you, nothing else.
            </p>

            <button
              type="button"
              @click="startGoogleSignIn"
              :disabled="busy"
              class="pressable mt-4 flex min-h-12 w-full items-center justify-center gap-2 rounded-xl border border-paper-line bg-paper font-semibold text-ink disabled:opacity-50"
            >
              <svg width="18" height="18" viewBox="0 0 24 24" aria-hidden="true">
                <path fill="#4285F4" d="M23.5 12.27c0-.85-.08-1.67-.22-2.45H12v4.64h6.46c-.28 1.5-1.13 2.77-2.4 3.62v3h3.88c2.27-2.09 3.56-5.17 3.56-8.81z"/>
                <path fill="#34A853" d="M12 24c3.24 0 5.96-1.07 7.94-2.92l-3.88-3c-1.08.72-2.45 1.15-4.06 1.15-3.12 0-5.77-2.11-6.71-4.94H1.28v3.1C3.25 21.3 7.31 24 12 24z"/>
                <path fill="#FBBC05" d="M5.29 14.29a7.2 7.2 0 010-4.58v-3.1H1.28a12 12 0 000 10.78z"/>
                <path fill="#EA4335" d="M12 4.75c1.76 0 3.34.61 4.59 1.8l3.44-3.44C17.95 1.19 15.24 0 12 0 7.31 0 3.25 2.7 1.28 6.61l4.01 3.1C6.23 6.86 8.88 4.75 12 4.75z"/>
              </svg>
              <span x-text="busy ? 'Opening Google…' : 'Sign in with Google'"></span>
            </button>

            <div class="my-4 flex items-center gap-3 text-xs font-medium text-ink-3">
              <div class="h-px flex-1 bg-paper-line"></div>
              <span>or</span>
              <div class="h-px flex-1 bg-paper-line"></div>
            </div>

            <form @submit.prevent="sendCode">
              <label class="block text-sm font-medium text-ink-2" for="phone-input">Sign in with phone number</label>
              <input
                id="phone-input"
                x-model="phone"
                type="tel"
                inputmode="tel"
                autocomplete="tel"
                placeholder="+2547..."
                class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
              />
              <p x-show="error" x-cloak class="mt-2 text-sm font-medium text-brick" x-text="error"></p>
              <button
                type="submit"
                :disabled="busy"
                class="pressable mt-4 min-h-12 w-full rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)] disabled:opacity-50"
              >
                <span x-text="busy ? 'Sending…' : 'Send code'"></span>
              </button>
            </form>
          </section>
        </template>

        <!-- OTP entry -->
        <template x-if="stage === 'otp'">
          <section class="paper relative rotate-[-0.5deg] p-5">
            <h2 class="font-display text-lg font-semibold text-ink">Enter the code</h2>
            <p class="mt-1 text-sm font-light text-ink-2">
              Sent by SMS to <span class="font-semibold text-ink" x-text="phone"></span>.
            </p>
            <form class="mt-4" @submit.prevent="verifyCode">
              <label class="block text-sm font-medium text-ink-2" for="otp-input">Code</label>
              <input
                id="otp-input"
                x-model="otp"
                type="text"
                inputmode="numeric"
                autocomplete="one-time-code"
                maxlength="8"
                placeholder="123456"
                class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
              />
              <p x-show="error" x-cloak class="mt-2 text-sm font-medium text-brick" x-text="error"></p>
              <button
                type="submit"
                :disabled="busy"
                class="pressable mt-4 min-h-12 w-full rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)] disabled:opacity-50"
              >
                <span x-text="busy ? 'Verifying…' : 'Verify'"></span>
              </button>
              <button
                type="button"
                @click="stage = 'phone'; otp = ''; error = ''"
                class="pressable mt-2 min-h-11 w-full rounded-xl text-sm font-medium text-ink-3"
              >
                Use a different number
              </button>
            </form>
          </section>
        </template>

        <!-- Import: account is empty, this device has data -->
        <template x-if="stage === 'import'">
          <section class="paper relative rotate-[-0.5deg] p-5">
            <h2 class="font-display text-lg font-semibold text-ink">Import your existing data?</h2>
            <p class="mt-2 text-sm font-light leading-relaxed text-ink-2">
              This account doesn't have any data yet, but this device does. Bring your current
              allowance, goals, and streak into your account so nothing already tracked here is lost.
            </p>
            <button
              type="button"
              @click="importLocalData"
              :disabled="busy"
              class="pressable mt-4 min-h-12 w-full rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)] disabled:opacity-50"
            >
              <span x-text="busy ? 'Importing…' : 'Import this device data'"></span>
            </button>
          </section>
        </template>

        <!-- Reconcile: both this device and the account have data -->
        <template x-if="stage === 'reconcile'">
          <section class="paper relative rotate-[-0.5deg] p-5">
            <h2 class="font-display text-lg font-semibold text-ink">Two copies of your data exist</h2>
            <p class="mt-2 text-sm font-light leading-relaxed text-ink-2">
              This device already has its own tracking, and your account already has data from
              somewhere else. Pick which one to keep. The other is not merged in automatically, so
              nothing gets silently combined or lost without you choosing.
            </p>
            <div class="mt-4 space-y-2">
              <button
                type="button"
                @click="keepThisDevice"
                :disabled="busy"
                class="chip pressable flex min-h-12 w-full items-center justify-center rounded-xl font-semibold text-ink disabled:opacity-50"
              >
                Keep this device's data
              </button>
              <button
                type="button"
                @click="useAccountData"
                :disabled="busy"
                class="chip pressable flex min-h-12 w-full items-center justify-center rounded-xl font-semibold text-ink disabled:opacity-50"
              >
                Use my account's data
              </button>
            </div>
          </section>
        </template>
      </div>
    </template>
  </main>
</Layout>
