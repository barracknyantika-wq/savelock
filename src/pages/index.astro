---
import Layout from '../layouts/Layout.astro';
---

<Layout title="SaveLock — Today" tab="today">
  <main x-data="todayPage" class="mx-auto w-full max-w-md px-5 pb-44 pt-7">
    <header class="mb-7 flex items-baseline justify-between px-1">
      <h1 class="font-display text-xl font-semibold tracking-tight text-cream">SaveLock</h1>
      <p class="text-sm font-light text-cream-2" x-text="$store.sl.dateLong()"></p>
    </header>

    <!-- Deep SMS reconciliation alert: transactions seen in the inbox but never logged -->
    <section
      x-show="$store.sl.reconciliationAlert.length"
      x-cloak
      class="paper relative mb-5 rotate-[-0.6deg] border-brick/40 p-5"
    >
      <h2 class="font-display text-lg font-semibold text-brick">
        <span x-text="$store.sl.reconciliationAlert.length"></span>
        <span x-text="$store.sl.reconciliationAlert.length === 1 ? 'transaction' : 'transactions'"></span>
        may not have been captured
      </h2>
      <ul class="mt-2 space-y-1 text-sm text-ink-2">
        <template x-for="tx in $store.sl.reconciliationAlert" :key="tx.mpesaCode">
          <li x-text="$store.sl.money(tx.amount) + ' · ' + (tx.counterparty || tx.type)"></li>
        </template>
      </ul>
      <div class="mt-3 flex gap-3">
        <button
          type="button"
          @click="$store.sl.dismissReconciliationAlert(); $toast('Dismissed')"
          class="pressable min-h-11 flex-1 rounded-xl border border-paper-line text-sm font-medium text-ink-2"
        >
          Dismiss
        </button>
        <button
          type="button"
          @click="$store.sl.drainNativeTransactions($store.sl.reconciliationAlert); $store.sl.dismissReconciliationAlert(); $toast('Logged')"
          class="pressable min-h-11 flex-1 rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)]"
        >
          Log them
        </button>
      </div>
    </section>

    <!-- First run: no daily limit set yet -->
    <section x-show="!$store.sl.hasLimit" x-cloak class="paper relative rotate-[-1.2deg] p-6">
      <span class="tape" aria-hidden="true"></span>
      <h2 class="font-display text-2xl font-semibold tracking-tight">Set a daily limit</h2>
      <p class="mt-2 text-sm leading-relaxed text-ink-2">
        How much can you spend in a day and still be fine at the end of the month?
        End each day at zero or better and your streak grows.
      </p>
      <form class="mt-5 flex gap-3" @submit.prevent="saveLimit">
        <label class="sr-only" for="limit-input">Daily limit</label>
        <input
          id="limit-input"
          x-model="limitInput"
          type="number"
          inputmode="decimal"
          min="1"
          step="any"
          placeholder="e.g. 500"
          class="min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
        />
        <button
          type="submit"
          class="pressable min-h-12 shrink-0 rounded-xl bg-ochre px-5 font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)]"
        >
          Start
        </button>
      </form>
    </section>

    <template x-if="$store.sl.hasLimit">
      <div>
        <!-- Hero: a tilted note stuck to the canvas -->
        <section class="paper relative z-10 rotate-[-2deg] px-6 pb-5 pt-7" aria-live="polite">
          <span class="tape" aria-hidden="true"></span>

          <p class="text-xs font-light uppercase tracking-[0.22em] text-ink-3">Left today</p>
          <p class="mt-1 leading-none">
            <span
              class="align-baseline text-xl font-light text-ink-2"
              x-text="$store.sl.settings.currency"
            ></span>
            <span
              class="font-display text-[64px] font-bold tracking-tight"
              :class="$store.sl.remaining < 0 ? 'text-brick' : 'text-ink'"
              x-text="$store.sl.fmt($store.sl.remaining)"
            ></span>
          </p>
          <p class="mt-1.5 text-sm font-light text-ink-2">
            <span x-text="'of ' + $store.sl.money($store.sl.settings.dailyLimit)"></span>
            · resets at midnight
          </p>
          <p
            x-show="$store.sl.remaining < 0"
            x-cloak
            class="mt-2 text-sm font-medium text-brick"
            x-text="'⚠ ' + $store.sl.money(Math.abs($store.sl.remaining)) + ' over — today ends the streak'"
          ></p>

          <!-- tick-mark arc gauge -->
          <div
            class="relative mx-auto mt-4 w-52"
            role="progressbar"
            aria-label="Share of today's allowance remaining"
            :aria-valuenow="Math.round($store.sl.remainingRatio * 100)"
            aria-valuemin="0"
            aria-valuemax="100"
          >
            <div x-html="allowanceGauge"></div>
            <p class="absolute inset-x-0 bottom-0 text-center">
              <span
                class="font-display text-2xl font-semibold text-ink"
                x-text="Math.round($store.sl.remainingRatio * 100) + '%'"
              ></span>
              <span class="block text-[10px] uppercase tracking-[0.18em] text-ink-3">remaining</span>
            </p>
          </div>

          <!-- streak, hand-underlined when alive -->
          <div class="mt-5 flex flex-col items-center pb-1">
            <p
              class="text-sm font-medium"
              :class="$store.sl.streak.count > 0 ? 'text-ochre-deep' : 'text-ink-3'"
              x-text="$store.sl.streak.count > 0
                ? $store.sl.streak.count + ($store.sl.streak.count === 1 ? ' day' : ' days') + ' under budget'
                : 'No streak yet — end today at zero or better'"
            ></p>
            <span x-show="$store.sl.streak.count > 0" x-cloak x-html="$squiggle()"></span>
          </div>
        </section>

        <!-- Log a spend: overlaps the hero's bottom edge, offset right -->
        <section class="paper relative z-20 -mt-3 ml-4 rotate-[0.8deg] p-5">
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-3">Log a spend</h2>
          <div class="mt-3 grid grid-cols-4 gap-2.5">
            <template x-for="q in quick" :key="q">
              <button
                type="button"
                @click="logQuick(q)"
                class="chip pressable min-h-14 rounded-2xl text-lg font-semibold text-ink"
                x-text="q"
              ></button>
            </template>
            <button
              type="button"
              @click="openSheet"
              class="pressable min-h-14 rounded-2xl bg-ink text-sm font-semibold text-cream shadow-[0_3px_0_rgba(0,0,0,0.4)]"
            >
              Other…
            </button>
          </div>
        </section>

        <!-- Last 7 days, sketchy bars -->
        <section class="paper relative z-0 -mt-2 mr-5 rotate-[-0.7deg] p-5 pt-4">
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-3">Last 7 days</h2>
          <div class="mt-2" x-html="historyChart"></div>
        </section>

        <!-- Spending insight: where did my money go -->
        <section class="paper relative z-0 mt-4 ml-3 rotate-[0.5deg] p-5">
          <div class="flex items-center justify-between">
            <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-3">Where it went</h2>
            <div class="flex gap-1 rounded-full bg-paper-deep p-0.5">
              <button
                type="button"
                @click="insightDays = 7"
                class="pressable rounded-full px-2.5 py-1 text-[11px] font-semibold"
                :class="insightDays === 7 ? 'bg-paper text-ink shadow-sm' : 'text-ink-3'"
              >
                Week
              </button>
              <button
                type="button"
                @click="insightDays = 30"
                class="pressable rounded-full px-2.5 py-1 text-[11px] font-semibold"
                :class="insightDays === 30 ? 'bg-paper text-ink shadow-sm' : 'text-ink-3'"
              >
                Month
              </button>
            </div>
          </div>

          <p
            x-show="!insightBreakdown.length"
            class="mt-3 rounded-xl border border-dashed border-paper-line px-4 py-5 text-center text-sm text-ink-3"
          >
            Nothing to show for this period yet.
          </p>

          <template x-if="insightBreakdown.length">
            <div>
              <div class="mt-3" x-html="insightChart"></div>
              <div class="mt-4 space-y-1.5 border-t border-dashed border-paper-line pt-3">
                <template x-for="c in topCategories" :key="c.category">
                  <div class="flex items-center justify-between text-sm">
                    <span class="font-semibold text-ink" x-text="c.category"></span>
                    <span class="font-light text-ink-2">
                      <span x-text="$store.sl.money(c.total)"></span>
                      <span class="text-ink-3" x-text="' (' + Math.round(c.pct * 100) + '%)'"></span>
                    </span>
                  </div>
                </template>
              </div>
            </div>
          </template>
        </section>

        <!-- Today's spends -->
        <section class="paper relative mt-4 ml-2 rotate-[0.4deg] p-5">
          <h2 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-3">
            Today
            <span
              class="normal-case tracking-normal"
              x-show="$store.sl.day.spends.length"
              x-text="'— ' + $store.sl.money($store.sl.spentToday) + ' spent'"
            ></span>
          </h2>

          <p
            x-show="confirmBanner"
            x-cloak
            x-transition
            class="mt-3 flex items-start gap-1.5 rounded-xl bg-ochre/10 px-3 py-2.5 text-sm text-ochre-deep"
          >
            <span x-html="$handCheck()"></span>
            <span x-text="confirmBanner"></span>
          </p>

          <p
            x-show="!$store.sl.day.spends.length"
            class="mt-3 rounded-xl border border-dashed border-paper-line px-4 py-5 text-center text-sm text-ink-3"
          >
            Nothing logged yet today.
          </p>
          <ul x-show="$store.sl.day.spends.length" x-cloak class="mt-1 divide-y divide-dashed divide-paper-line">
            <template x-for="s in [...$store.sl.day.spends].reverse()" :key="s.id">
              <li class="flex items-center gap-2 py-2.5">
                <div class="min-w-0 flex-1">
                  <p class="font-semibold tabular-nums text-ink" x-text="$store.sl.money(s.amount)"></p>
                  <p class="truncate text-xs font-light text-ink-2">
                    <span x-text="$store.sl.time(s.at)"></span><span x-show="s.note" x-text="' · ' + s.note"></span>
                    <span
                      x-show="s.source === 'sms'"
                      class="ml-1 rounded-full bg-paper-deep px-1.5 py-0.5 text-[9px] font-semibold uppercase tracking-wide text-ink-3"
                      >M-Pesa</span
                    >
                    <span
                      x-show="s.viaFuliza"
                      x-cloak
                      class="ml-1 rounded-full bg-brick/15 px-1.5 py-0.5 text-[9px] font-semibold uppercase tracking-wide text-brick"
                      :title="'Ksh ' + (s.fulizaAmount ?? '') + ' covered by Fuliza overdraft'"
                      >Fuliza</span
                    >
                  </p>
                </div>
                <button
                  type="button"
                  @click="openCategoryEdit(s.id)"
                  class="pressable shrink-0 rounded-full bg-paper-deep px-2.5 py-1.5 text-[11px] font-semibold text-ink-2"
                  :aria-label="'Change category, currently ' + (s.category || 'Other')"
                  x-text="s.category || 'Other'"
                ></button>
                <button
                  type="button"
                  x-show="$store.sl.activeGoals.length"
                  @click="openReclassify(s.id)"
                  class="pressable flex h-11 w-11 shrink-0 items-center justify-center rounded-xl text-ink-3 active:text-ochre-deep"
                  :aria-label="'Move ' + $store.sl.money(s.amount) + ' to a savings goal instead'"
                  title="Not spending — move to a goal"
                >
                  <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <rect x="5" y="10.5" width="14" height="9" rx="2.2" />
                    <path d="M8 10.5V8a4 4 0 0 1 8 0v2.5" />
                    <path d="M12 3.5v7M9.3 8.2 12 5.5l2.7 2.7" />
                  </svg>
                </button>
                <button
                  type="button"
                  @click="$store.sl.deleteSpend(s.id); $toast('Deleted')"
                  class="pressable flex h-11 w-11 shrink-0 items-center justify-center rounded-xl text-ink-3 active:text-brick"
                  :aria-label="'Delete spend of ' + $store.sl.money(s.amount)"
                >
                  <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 7h16M10 11v6M14 11v6M6 7l1 13h10l1-13M9 7V4h6v3" />
                  </svg>
                </button>
              </li>
            </template>
          </ul>
        </section>
      </div>
    </template>

    <!-- Reclassify sheet: "this wasn't spending" -->
    <div
      x-show="reclassifyId"
      x-cloak
      class="fixed inset-0 z-50"
      role="dialog"
      aria-modal="true"
      aria-label="Move to a savings goal"
    >
      <div
        class="absolute inset-0 bg-black/60"
        x-show="reclassifyId"
        x-transition.opacity.duration.150ms
        @click="reclassifyId = null"
      ></div>
      <div
        x-show="reclassifyId"
        x-transition:enter="transition duration-200 ease-out"
        x-transition:enter-start="translate-y-full"
        x-transition:enter-end="translate-y-0"
        x-transition:leave="transition duration-150 ease-in"
        x-transition:leave-start="translate-y-0"
        x-transition:leave-end="translate-y-full"
        class="paper absolute inset-x-0 bottom-0 rounded-b-none rounded-t-3xl p-5 pb-[calc(1.5rem+env(safe-area-inset-bottom))]"
      >
        <div class="mx-auto max-w-md">
          <div class="mx-auto mb-3 h-1.5 w-10 rounded-full bg-paper-line" aria-hidden="true"></div>
          <h3 class="font-display text-xl font-semibold tracking-tight">Not spending?</h3>
          <p class="mt-1 text-sm font-light text-ink-2">
            <span x-text="reclassifySpend ? $store.sl.money(reclassifySpend.amount) : ''"></span>
            moves off today's spending and into a goal's saved total instead. No money moves — this only fixes the score.
          </p>
          <div class="mt-4 space-y-2">
            <template x-for="g in activeGoals" :key="g.id">
              <button
                type="button"
                @click="confirmReclassify(g.id)"
                class="chip pressable flex min-h-12 w-full items-center justify-between rounded-xl px-4 text-left"
              >
                <span class="font-semibold text-ink" x-text="g.name"></span>
                <span class="text-xs font-light text-ink-2" x-text="$store.sl.money(g.saved) + ' of ' + $store.sl.money(g.target)"></span>
              </button>
            </template>
          </div>
          <button
            type="button"
            @click="reclassifyId = null"
            class="pressable mt-4 min-h-12 w-full rounded-xl border border-paper-line font-semibold text-ink-2"
          >
            Cancel
          </button>
        </div>
      </div>
    </div>

    <!-- Category-edit sheet -->
    <div
      x-show="categoryEditId"
      x-cloak
      class="fixed inset-0 z-50"
      role="dialog"
      aria-modal="true"
      aria-label="Change category"
    >
      <div
        class="absolute inset-0 bg-black/60"
        x-show="categoryEditId"
        x-transition.opacity.duration.150ms
        @click="categoryEditId = null"
      ></div>
      <div
        x-show="categoryEditId"
        x-transition:enter="transition duration-200 ease-out"
        x-transition:enter-start="translate-y-full"
        x-transition:enter-end="translate-y-0"
        x-transition:leave="transition duration-150 ease-in"
        x-transition:leave-start="translate-y-0"
        x-transition:leave-end="translate-y-full"
        class="paper absolute inset-x-0 bottom-0 rounded-b-none rounded-t-3xl p-5 pb-[calc(1.5rem+env(safe-area-inset-bottom))]"
      >
        <div class="mx-auto max-w-md">
          <div class="mx-auto mb-3 h-1.5 w-10 rounded-full bg-paper-line" aria-hidden="true"></div>
          <h3 class="font-display text-xl font-semibold tracking-tight">Category</h3>
          <p class="mt-1 text-sm font-light text-ink-2">
            <span x-text="categoryEditSpend ? $store.sl.money(categoryEditSpend.amount) : ''"></span>
            <span x-show="categoryEditSpend?.note" x-text="' · ' + categoryEditSpend?.note"></span>
          </p>
          <div class="mt-4 flex flex-wrap gap-2">
            <template x-for="c in categories" :key="c">
              <button
                type="button"
                @click="setCategory(c)"
                class="chip pressable rounded-full px-4 py-2 text-sm font-semibold"
                :class="categoryEditSpend?.category === c ? 'bg-ochre text-ink' : 'text-ink'"
                x-text="c"
              ></button>
            </template>
          </div>
          <button
            type="button"
            @click="categoryEditId = null"
            class="pressable mt-5 min-h-12 w-full rounded-xl border border-paper-line font-semibold text-ink-2"
          >
            Cancel
          </button>
        </div>
      </div>
    </div>

    <!-- Custom amount sheet -->
    <div x-show="sheet" x-cloak class="fixed inset-0 z-50" role="dialog" aria-modal="true" aria-label="Log a spend">
      <div
        class="absolute inset-0 bg-black/60"
        x-show="sheet"
        x-transition.opacity.duration.150ms
        @click="sheet = false"
      ></div>
      <form
        @submit.prevent="submitSpend"
        x-show="sheet"
        x-transition:enter="transition duration-200 ease-out"
        x-transition:enter-start="translate-y-full"
        x-transition:enter-end="translate-y-0"
        x-transition:leave="transition duration-150 ease-in"
        x-transition:leave-start="translate-y-0"
        x-transition:leave-end="translate-y-full"
        class="paper absolute inset-x-0 bottom-0 rounded-b-none rounded-t-3xl p-5 pb-[calc(1.5rem+env(safe-area-inset-bottom))]"
      >
        <div class="mx-auto max-w-md">
          <div class="mx-auto mb-3 h-1.5 w-10 rounded-full bg-paper-line" aria-hidden="true"></div>
          <h3 class="font-display text-xl font-semibold tracking-tight">Log a spend</h3>
          <label class="mt-4 block text-sm font-medium text-ink-2" for="spend-amount">Amount</label>
          <input
            id="spend-amount"
            x-ref="amountInput"
            x-model="amount"
            type="number"
            inputmode="decimal"
            min="0"
            step="any"
            placeholder="0"
            class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
          />
          <label class="mt-3 block text-sm font-medium text-ink-2" for="spend-note">
            Note <span class="font-light text-ink-3">(optional)</span>
          </label>
          <input
            id="spend-note"
            x-model="note"
            type="text"
            maxlength="60"
            placeholder="lunch, fare…"
            class="mt-1 min-h-12 w-full rounded-xl border border-paper-line bg-paper-deep px-4 text-base text-ink outline-none placeholder:text-ink-3 focus:border-ochre-soft"
          />
          <label class="mt-3 block text-sm font-medium text-ink-2">Category</label>
          <div class="mt-1.5 flex flex-wrap gap-2">
            <template x-for="c in categories" :key="c">
              <button
                type="button"
                @click="category = c"
                class="chip pressable rounded-full px-3.5 py-1.5 text-sm font-semibold"
                :class="category === c ? 'bg-ochre text-ink' : 'text-ink'"
                x-text="c"
              ></button>
            </template>
          </div>
          <div class="mt-5 flex gap-3">
            <button
              type="button"
              @click="sheet = false"
              class="pressable min-h-12 flex-1 rounded-xl border border-paper-line font-semibold text-ink-2"
            >
              Cancel
            </button>
            <button
              type="submit"
              class="pressable min-h-12 flex-1 rounded-xl bg-ochre font-semibold text-ink shadow-[0_3px_0_rgba(140,100,20,0.55)]"
            >
              Log it
            </button>
          </div>
        </div>
      </form>
    </div>
  </main>
</Layout>
