<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
              Deep link for completing Google Sign-In (Supabase OAuth). The
              consent screen runs in the system browser, not this WebView
              (Google blocks OAuth from embedded WebViews) — this is only
              how the browser hands control back to the app afterward.
              com.savelock.app://auth-callback must also be added to
              Supabase's Redirect URLs allowlist, see SUPABASE_SETUP.md.
            -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="com.savelock.app" android:host="auth-callback" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>

        <!--
          Declared (not runtime-registered) so this keeps receiving the SMS
          broadcast even when the app's process isn't running. The
          android:permission restricts who may send this broadcast to the
          system itself — it is not the app's own runtime permission grant,
          which is requested separately (RECEIVE_SMS below) before this can
          ever fire in practice.
        -->
        <receiver
            android:name=".SmsReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!--
      Deliberately RECEIVE_SMS only, not READ_SMS, for the core auto-detect
      feature: it only ever sees the message contained in the SMS_RECEIVED
      broadcast extras, never the device's SMS history/inbox.
      POST_NOTIFICATIONS is required at runtime on Android 13+ for the
      confirmation notification to be allowed to show.
    -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      READ_SMS is separate: only used for the opt-in "Deep SMS
      reconciliation" feature (off by default), which reads M-Pesa messages
      from the inbox specifically to double-check nothing was missed by the
      always-on auto-detect above. Never requested unless the user turns
      that feature on from Settings, with its own consent explanation first.
    -->
    <uses-permission android:name="android.permission.READ_SMS" />
</manifest>
